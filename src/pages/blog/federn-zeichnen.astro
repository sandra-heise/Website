---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/blog/federn-zeichnen`;
const ogImage = `${SITE}/blog/federn-zeichnen-hero.jpg`;

const schritte = [
  {
    name: "Skizze anlegen",
    text: "Zeichne mit dem HB-Bleistift eine leicht geschwungene Mittellinie — das ist der Schaft der Feder. Beidseitig davon zwei weitere Linien, die sich zur Spitze hin angleichen. Füge an den Seiten leicht geschwungene Einkerbungen hinzu, um die typische Blattform einer Feder anzudeuten."
  },
  {
    name: "Federstruktur ausarbeiten",
    text: "Zeichne nun viele dünne Linien, die schräg vom Schaft nach außen verlaufen — in Richtung der Federspitze. Variiere Länge und Abstand der Linien, um die natürliche Unregelmäßigkeit einer echten Feder nachzubilden."
  },
  {
    name: "Schattierung hinzufügen",
    text: "Setze mit dem Kugelschreiber zusätzliche Linien für Schatteneffekte — besonders an der Federspitze und entlang des Schafts. Kürzere, dichtere Striche in diesen Bereichen geben der Feder Tiefe und Volumen."
  },
  {
    name: "Abschließende Details",
    text: "Zeichne einzelne lose Härchen entlang des Schafts, die kürzer als die Hauptstruktur sind und leicht von der Spitze wegzeigen. Verstärke den Schaft leicht — er bleibt aber dünn und läuft spitz aus. Fertig ist deine realistische Bleistift- und Kugelschreiberfeder!"
  }
];
---

<Layout
  title="Federn zeichnen – Schritt-für-Schritt-Anleitung für Anfänger | Sunny Artis"
  description="Lerne, wie du mit Bleistift und Kugelschreiber eine realistische Feder zeichnest — von der Skizze bis zum fertigen Detail. Eine einfache Anleitung für Einsteiger."
  ogImage={ogImage}
  canonical={canonicalUrl}
>
  <meta name="keywords" content="Federn zeichnen, Feder zeichnen Anleitung, Bleistiftzeichnung Feder, realistisch zeichnen lernen, Zeichenanleitung Anfänger, Sandra Heise Blog" slot="head" />
  <meta property="article:published_time" content="2024-01-11" slot="head" />
  <meta property="article:author" content="Sandra Heise" slot="head" />
  <meta property="article:section" content="Zeichnen Lernen" slot="head" />
  <meta property="article:tag" content="Zeichnen" slot="head" />
  <meta property="article:tag" content="Anleitung" slot="head" />
  <meta property="og:type" content="article" slot="head" />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "Federn zeichnen – Schritt-für-Schritt-Anleitung für Anfänger",
    "description": "Lerne, wie du mit Bleistift und Kugelschreiber eine realistische Feder zeichnest — von der Skizze bis zum fertigen Detail.",
    "image": ogImage,
    "datePublished": "2024-01-11",
    "dateModified": "2024-01-11",
    "keywords": "Federn zeichnen, Bleistiftzeichnung, Anleitung, Zeichnen lernen, realistisch",
    "inLanguage": "de",
    "url": canonicalUrl,
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    "author": { "@type": "Person", "name": "Sandra Heise", "url": SITE, "sameAs": ["https://www.instagram.com/sunny_artis/", "https://www.youtube.com/@SunnyArtis"] },
    "publisher": { "@type": "Person", "name": "Sandra Heise", "url": SITE },
    "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".article-title", ".article-container h2", ".step-text"] },
    "isPartOf": { "@type": "Blog", "name": "Sunny Artis Blog", "url": `${SITE}/blog` }
  })} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "Federn zeichnen – Schritt für Schritt",
    "description": "Wie du mit Bleistift und Kugelschreiber eine realistische Feder zeichnest.",
    "image": ogImage,
    "totalTime": "PT30M",
    "tool": [
      { "@type": "HowToTool", "name": "HB-Bleistift" },
      { "@type": "HowToTool", "name": "Kugelschreiber BIC Cristal Original" },
      { "@type": "HowToTool", "name": "Zeichenpapier" }
    ],
    "step": schritte.map((s, i) => ({
      "@type": "HowToStep",
      "position": i + 1,
      "name": s.name,
      "text": s.text
    }))
  })} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Welche Materialien brauche ich zum Federn zeichnen?",
        "acceptedAnswer": { "@type": "Answer", "text": "Du brauchst nur wenig: einen HB-Bleistift für die Skizze und einen schwarzen Kugelschreiber (z. B. BIC Cristal Original) für die feinen Linien und Details. Normales Zeichenpapier reicht völlig aus." }
      },
      {
        "@type": "Question",
        "name": "Ist die Anleitung auch für absolute Anfänger geeignet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja — die vier Schritte sind bewusst einfach gehalten. Du brauchst keine Vorkenntnisse. Übung macht den Meister: Probiere verschiedene Federformen aus und nutze Fotovorlagen zur Inspiration." }
      },
      {
        "@type": "Question",
        "name": "Wie lange dauert es, eine Feder zu zeichnen?",
        "acceptedAnswer": { "@type": "Answer", "text": "Eine einfache Feder ist in ca. 20–30 Minuten fertig. Mit mehr Übung und mehr Details kann eine Feder auch 1–2 Stunden in Anspruch nehmen — je nach Stil und Komplexität." }
      }
    ]
  })} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE}/blog` },
      { "@type": "ListItem", "position": 3, "name": "Federn zeichnen", "item": canonicalUrl }
    ]
  })} />

  <section class="article-hero">
    <div class="container">
      <div class="article-meta">
        <a href={`${base}/blog`} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Zurück zum Blog
        </a>
        <span class="article-category">Zeichnen Lernen</span>
      </div>
      <h1 class="article-title">Federn zeichnen – eine Schritt-für-Schritt-Anleitung</h1>
      <p class="article-date">11. Januar 2024 · von Sandra Heise</p>
    </div>
  </section>

  <article class="article-body">
    <div class="container article-container">

      <figure class="article-figure article-figure--top">
        <img src={`${base}/blog/federn-zeichnen-hero.jpg`} alt="Handgezeichnete Feder mit Bleistift und Kugelschreiber von Sandra Heise" fetchpriority="high" loading="eager" />
      </figure>

      <p>
        Federn sind Naturkunstwerke — sie faszinieren mit ihrer Anmut und Leichtigkeit. In der Kunst werden sie oft als Symbol für Freiheit und Leichtigkeit verwendet oder als präzise gezeichnetes Detail in realistischen Werken. In dieser Anleitung zeige ich dir, wie du Schritt für Schritt eine realistische Feder zeichnest — mit nur zwei Werkzeugen.
      </p>

      <div class="material-box">
        <h3>Materialien & Werkzeuge</h3>
        <ul>
          <li><strong>HB-Bleistift</strong> — für die Skizze und Grundstruktur</li>
          <li><strong>Schwarzer Kugelschreiber</strong> (z. B. <a href="https://amzn.to/468Bk0q" target="_blank" rel="noopener noreferrer sponsored">BIC Cristal Original</a>) — für feine Linien und Details</li>
          <li><strong>Zeichenpapier</strong> — normales Papier reicht aus</li>
        </ul>
      </div>

      <h2>Schritt für Schritt zur fertigen Feder</h2>

      {schritte.map((s, i) => (
        <div class="step-block">
          <div class="step-header">
            <span class="step-nr">{i + 1}</span>
            <h3 class="step-title">{s.name}</h3>
          </div>
          <p class="step-text">{s.text}</p>
        </div>
      ))}

      <h2>Tipps & Tricks</h2>
      <p>
        Experimentiere ruhig mit verschiedenen Federformen — gestreckte Federn, breite Varianten oder zweifarbige Designs sehen alle beeindruckend aus. Nutze Fotos aus der Natur oder dem Internet als Vorlage und beobachte genau, wie Licht und Schatten auf echten Federn wirken. Je mehr du übst, desto sicherer werden deine Linien.
      </p>
      <p>
        Trau dich, Fehler zu machen — gerade beim Zeichnen entstehen die schönsten Ergebnisse oft durch Ausprobieren. Und denk daran: Jede Feder, die du zeichnest, ist einzigartig — genau wie das Original.
      </p>

      <div class="fazit-box">
        <p><strong>Fazit:</strong> Das Zeichnen von Federn ist eine wunderbare Übung für alle, die realistisches Zeichnen lernen möchten. Mit ein wenig Geduld und den richtigen Werkzeugen entstehen Ergebnisse, auf die du stolz sein kannst.</p>
      </div>

      <div class="article-cta">
        <p>Auch Ausmalen macht kreativ — schau dir unsere Leinwände an:</p>
        <a href={`${base}/malen#leinwaende`} class="btn btn-accent">Ausmalleinwände ansehen</a>
      </div>

    </div>
  </article>

  <section class="section back-section bg-light">
    <div class="container text-center">
      <a href={`${base}/blog`} class="btn btn-secondary">Weitere Blog-Artikel</a>
    </div>
  </section>
</Layout>

<style>
  .article-hero { padding: 4rem 0 2.5rem; background: var(--color-bg-white); border-bottom: 1px solid var(--color-border); }
  .article-meta { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .back-link { display: flex; align-items: center; gap: 6px; font-family: var(--font-title); font-size: 0.88rem; font-weight: 600; color: var(--color-text-muted); transition: color var(--transition-fast); }
  .back-link:hover { color: var(--color-teal); }
  .article-category { font-family: var(--font-title); font-size: 0.78rem; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: 0.08em; background: rgba(1,170,193,0.1); padding: 3px 10px; border-radius: 20px; }
  .article-title { font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.2; color: var(--color-navy); max-width: 820px; margin-bottom: 0.75rem; }
  .article-date { font-family: var(--font-title); font-size: 0.88rem; color: var(--color-text-muted); }
  .article-body { padding: 3.5rem 0 4rem; }
  .article-container { max-width: 740px; margin: 0 auto; }
  .article-container p { font-size: 1.05rem; line-height: 1.85; color: var(--color-text); margin-bottom: 1.5rem; }
  .article-container h2 { font-size: 1.5rem; color: var(--color-navy); margin: 2.5rem 0 1.25rem; }
  .article-container a:not(.btn) { color: var(--color-teal); text-decoration: underline; text-underline-offset: 3px; }
  .article-container a:not(.btn):hover { color: var(--color-navy); }
  .article-figure { margin: 2rem 0 2.5rem; }
  .article-figure--top img { width: 100%; height: auto; border-radius: 12px; box-shadow: var(--shadow-md); display: block; }
  .article-cta { background: var(--color-bg-light); border-left: 4px solid var(--color-teal); border-radius: 0 12px 12px 0; padding: 1.5rem 2rem; margin-top: 2.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .article-cta p { margin: 0 !important; font-weight: 500; flex: 1; min-width: 200px; }
  .back-section { padding: 3rem 0; }
  .material-box { background: var(--color-bg-light); border-radius: 12px; padding: 1.5rem 2rem; margin: 2rem 0 2.5rem; }
  .material-box h3 { color: var(--color-navy); font-size: 1.05rem; margin: 0 0 0.75rem; }
  .material-box ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .material-box li { font-size: 0.95rem; color: var(--color-text-muted); }
  .step-block { margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
  .step-block:last-of-type { border-bottom: none; }
  .step-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
  .step-nr { width: 2rem; height: 2rem; border-radius: 50%; background: var(--color-teal); color: white; font-family: var(--font-title); font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .step-title { font-size: 1.15rem; color: var(--color-navy); margin: 0; font-family: var(--font-title); font-weight: 700; }
  .step-text { color: var(--color-text-muted); margin-bottom: 0 !important; }
  .fazit-box { background: rgba(1,170,193,0.08); border-radius: 12px; padding: 1.25rem 1.5rem; margin: 2rem 0; font-size: 1.05rem; line-height: 1.75; }
</style>
