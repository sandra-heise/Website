---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/blog/kreativmarkt-magdeburg`;
const ogImage = `${SITE}/blog/kreativmarkt-hero.png`;
---

<Layout
  title="Ein Wochenende voller Kreativität – Kreativmarkt Magdeburg 2024 | Sunny Artis"
  description="Unser viertes Jahr als Aussteller auf dem Kreativmarkt Magdeburg: Begegnungen, Inspiration und handgemachte Produkte. Ein Rückblick auf ein unvergessliches Wochenende."
  ogImage={ogImage}
  canonical={canonicalUrl}
>
  <meta name="keywords" content="Kreativmarkt Magdeburg, Handmade Messe, Kreativmarkt Aussteller, Sandra Heise Messe, Sunny Artis Kreativmarkt, handgemachte Produkte Magdeburg" slot="head" />
  <meta property="article:published_time" content="2024-01-22" slot="head" />
  <meta property="article:author" content="Sandra Heise" slot="head" />
  <meta property="article:section" content="Events & Messen" slot="head" />
  <meta property="article:tag" content="Kreativmarkt" slot="head" />
  <meta property="article:tag" content="Magdeburg" slot="head" />
  <meta property="og:type" content="article" slot="head" />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "Ein Wochenende voller Kreativität – Kreativmarkt Magdeburg 2024",
    "description": "Unser viertes Jahr als Aussteller auf dem Kreativmarkt Magdeburg: Begegnungen, Inspiration und handgemachte Produkte.",
    "image": ogImage,
    "datePublished": "2024-01-22",
    "dateModified": "2024-01-22",
    "keywords": "Kreativmarkt Magdeburg, Handmade Messe, Aussteller, Sandra Heise",
    "inLanguage": "de",
    "url": canonicalUrl,
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    "author": { "@type": "Person", "name": "Sandra Heise", "url": SITE, "sameAs": ["https://www.instagram.com/sunny_artis/"] },
    "publisher": { "@type": "Person", "name": "Sandra Heise", "url": SITE },
    "about": { "@type": "Event", "name": "Kreativmarkt Magdeburg 2024", "location": { "@type": "Place", "name": "Magdeburg", "address": { "@type": "PostalAddress", "addressLocality": "Magdeburg", "addressCountry": "DE" } } },
    "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".article-title", ".article-container h2", ".article-container p"] },
    "isPartOf": { "@type": "Blog", "name": "Sunny Artis Blog", "url": `${SITE}/blog` }
  })} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE}/blog` },
      { "@type": "ListItem", "position": 3, "name": "Kreativmarkt Magdeburg", "item": canonicalUrl }
    ]
  })} />

  <section class="article-hero">
    <div class="container">
      <div class="article-meta">
        <a href={`${base}/blog`} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Zurück zum Blog
        </a>
        <span class="article-category">Events & Messen</span>
      </div>
      <h1 class="article-title">Ein Wochenende voller Kreativität auf dem Kreativmarkt Magdeburg</h1>
      <p class="article-date">22. Januar 2024 · von Sandra Heise</p>
    </div>
  </section>

  <article class="article-body">
    <div class="container article-container">

      <figure class="article-figure article-figure--top">
        <img src={`${base}/blog/kreativmarkt-hero.png`} alt="Sunny Artis Stand auf dem Kreativmarkt Magdeburg 2024" fetchpriority="high" loading="eager" />
      </figure>

      <p>
        Der Kreativmarkt Magdeburg ist für uns jedes Jahr ein ganz besonderes Ereignis — ein Ort, an dem Handgemachtes, Leidenschaft und Begegnung zusammenkommen. Dieses Jahr war es bereits unser <strong>viertes Mal als Aussteller</strong>, und es war wieder ein unvergessliches Wochenende.
      </p>

      <h2>Was der Kreativmarkt besonders macht</h2>
      <p>
        Der Kreativmarkt findet einmal jährlich in Magdeburg statt und ist auch in anderen Städten wie Chemnitz, Erfurt und Leipzig zu Gast. Für alle, die handgemachte Produkte lieben, ist er eine echte Fundgrube: Stoffe, Backformen, Regionales, Schmuck, 3D-Druck-Objekte, bestickte Taschen und vieles mehr warten auf Besucher und Besucherinnen. Eine bunte Mischung aus Kreativität und Handwerk — und genau das macht den Charme dieser Messe aus.
      </p>
      <p>
        Nach den schwierigen Jahren rund um die Pandemie erlebt der Kreativmarkt eine spürbare Wiederbelebung: Die Besucherzahlen wachsen, die Begeisterung für handgemachte Produkte ist wieder da — vielleicht sogar stärker als je zuvor.
      </p>

      <h2>Unser Aufbau und der neue Banner</h2>
      <p>
        Der Aufbau fand am Freitag statt, und dieses Jahr hatten wir etwas ganz Besonderes dabei: unseren brandneuen Banner. Als Eckstandinhaber hatten wir eine tolle Präsenz, die viele Blicke auf sich zog. Am Samstag öffnete der Markt von 11 bis 18 Uhr, am Sonntag von 10 bis 17 Uhr — zwei intensive, aber wunderschöne Tage.
      </p>

      <div class="bild-grid">
        <figure>
          <img src={`${base}/blog/kreativmarkt-2.png`} alt="Sunny Artis Produkte auf dem Kreativmarkt Magdeburg" loading="lazy" />
        </figure>
        <figure>
          <img src={`${base}/blog/kreativmarkt-3.png`} alt="Besucher am Sunny Artis Stand" loading="lazy" />
        </figure>
      </div>

      <h2>Austausch, Inspiration und Gemeinschaft</h2>
      <p>
        Wir präsentierten unsere <a href={`${base}/malen#leinwaende`}>Ausmalleinwände</a>, <a href={`${base}/malen#malbuecher`}>Malbücher</a>, Schmuckstücke und Poster. Was aber noch mehr zählt als jeder Verkauf: der direkte Austausch mit Menschen, die unsere Produkte in die Hand nehmen, darüber staunen und Fragen stellen. Solche Begegnungen sind durch nichts zu ersetzen.
      </p>
      <p>
        Wir haben außerdem viele andere kreative Aussteller kennengelernt, uns gegenseitig inspiriert und ein Stück dieser besonderen Energie mitgenommen, die nur auf solchen Märkten entsteht. Kreativität ist ansteckend — auf die schönste Art.
      </p>

      <h2>Bis zum nächsten Jahr</h2>
      <p>
        Ein herzliches Dankeschön an alle, die uns besucht haben, die unser Sortiment unterstützen und uns Jahr für Jahr ermutigen, dabei zu sein. Wir freuen uns schon riesig auf das nächste Mal — dann mit noch mehr Produkten und noch mehr Ideen im Gepäck.
      </p>

      <div class="article-cta">
        <p>Unsere Produkte gibt es auch online:</p>
        <a href={`${base}/malen`} class="btn btn-accent">Zum Shop</a>
      </div>

    </div>
  </article>

  <section class="section back-section bg-light">
    <div class="container text-center">
      <a href={`${base}/blog`} class="btn btn-secondary">Weitere Blog-Artikel</a>
    </div>
  </section>
</Layout>

<style>
  .article-hero { padding: 4rem 0 2.5rem; background: var(--color-bg-white); border-bottom: 1px solid var(--color-border); }
  .article-meta { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .back-link { display: flex; align-items: center; gap: 6px; font-family: var(--font-title); font-size: 0.88rem; font-weight: 600; color: var(--color-text-muted); transition: color var(--transition-fast); }
  .back-link:hover { color: var(--color-teal); }
  .article-category { font-family: var(--font-title); font-size: 0.78rem; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: 0.08em; background: rgba(1,170,193,0.1); padding: 3px 10px; border-radius: 20px; }
  .article-title { font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.2; color: var(--color-navy); max-width: 820px; margin-bottom: 0.75rem; }
  .article-date { font-family: var(--font-title); font-size: 0.88rem; color: var(--color-text-muted); }
  .article-body { padding: 3.5rem 0 4rem; }
  .article-container { max-width: 740px; margin: 0 auto; }
  .article-container p { font-size: 1.05rem; line-height: 1.85; color: var(--color-text); margin-bottom: 1.5rem; }
  .article-container h2 { font-size: 1.5rem; color: var(--color-navy); margin: 2.5rem 0 1rem; }
  .article-container a:not(.btn) { color: var(--color-teal); text-decoration: underline; text-underline-offset: 3px; }
  .article-container a:not(.btn):hover { color: var(--color-navy); }
  .article-figure { margin: 2rem 0 2.5rem; }
  .article-figure--top img { width: 100%; height: auto; border-radius: 12px; box-shadow: var(--shadow-md); display: block; }
  .article-cta { background: var(--color-bg-light); border-left: 4px solid var(--color-teal); border-radius: 0 12px 12px 0; padding: 1.5rem 2rem; margin-top: 2.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .article-cta p { margin: 0 !important; font-weight: 500; flex: 1; min-width: 200px; }
  .back-section { padding: 3rem 0; }
  .bild-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 2rem 0; border-radius: 12px; overflow: hidden; }
  .bild-grid figure { margin: 0; }
  .bild-grid img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
</style>
