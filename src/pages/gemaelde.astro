---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const gemaelde = [
  {
    id: 1,
    title: "Silent Crown",
    technik: "öl",
    techniklabel: "Öl auf Leinwand",
    format: "80 × 80 cm",
    preis: "525,00 €",
    beschreibung: "Modernes Frauenporträt mit geschlossenen Augen und aufgesetzter Krone. Farbakzente in Blau, Pink und Türkis vereinen Ruhe und Stärke in einer faszinierenden Komposition.",
    image: "/gemaelde/silent-crown.jpg",
    status: "trocknung",
    listingId: null,
    etsy: ""
  },
  {
    id: 2,
    title: "Blütengeist – Ausdruck einer Seele",
    technik: "öl",
    techniklabel: "Öl auf Leinwand",
    format: "80 × 80 cm",
    preis: "275,00 €",
    beschreibung: "Frauenporträt, zart von Blüten umrahmt — geheimnisvoll und verletzlich zugleich. Preisgekröntes Werk (7. Platz Kunst-Online-Wettbewerb).",
    image: "/gemaelde/blutengeist.jpg",
    status: "verfügbar",
    listingId: "4307467400",
    etsy: "https://www.etsy.com/de/listing/4307467400/ol-gemalde-original-frau-mit-blumen"
  },
  {
    id: 3,
    title: "Farbenfroh",
    technik: "öl",
    techniklabel: "Öl auf Leinwand",
    format: "80 × 80 cm",
    preis: "525,00 €",
    beschreibung: "Porträt einer Frau mit Rosen im Haar — leuchtende Farben und ein intensiver Blick verkörpern die Vielfalt weiblicher Gefühle und die Verbundenheit von Mensch und Natur.",
    image: "/gemaelde/farbenfroh.jpg",
    status: "verfügbar",
    listingId: "4365612544",
    etsy: "https://www.etsy.com/de/listing/4365612544/ol-gemalde-original-farbenfrohe-frau"
  },
  {
    id: 4,
    title: "Vergängliche Stärke",
    technik: "acryl",
    techniklabel: "Acryl, Strukturpaste & Blattgold",
    format: "40 × 50 cm",
    preis: "95,00 €",
    beschreibung: "Ausdrucksstarkes Männerporträt mit edlem Blattgold auf Schwarz und Weiß — metallischer Glanz trifft plastische Tiefe. Stärke und Zerbrechlichkeit in einem Unikat.",
    image: "/gemaelde/vergaengliche-staerke.jpg",
    status: "verfügbar",
    listingId: "4354656293",
    etsy: "https://www.etsy.com/de/listing/4354656293/acryl-gemalde-original-vergangliche"
  },
  {
    id: 5,
    title: "Vergängliche Stärke 2",
    technik: "acryl",
    techniklabel: "Acryl, Strukturpaste & Blattgold",
    format: "40 × 50 cm",
    preis: "95,00 €",
    beschreibung: "Das Folgewerk der Serie — dasselbe kraftvolle Sujet, noch intensiver im Ausdruck. Licht, Schatten und der Glanz des Blattgolds erzählen von Stärke und Vergänglichkeit.",
    image: "/gemaelde/vergaengliche-staerke-2.jpg",
    status: "verfügbar",
    listingId: "4354656511",
    etsy: "https://www.etsy.com/de/listing/4354656511/acryl-gemalde-original-vergangliche"
  },
];

const ETSY_API_KEY = import.meta.env.ETSY_API_KEY;

async function fetchEtsyPrice(listingId: string | null) {
  if (!ETSY_API_KEY || !listingId) return null;
  try {
    const res = await fetch(`https://openapi.etsy.com/v3/application/listings/${listingId}`, {
      headers: { 'x-api-key': ETSY_API_KEY }
    });
    if (!res.ok) return null;
    const data = await res.json();
    const { amount, divisor, currency_code } = data.price;
    const value = (amount / divisor).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return `${value} ${currency_code === 'EUR' ? '€' : currency_code}`;
  } catch {
    return null;
  }
}

await Promise.all(
  gemaelde.map(async (g) => {
    const livePreis = await fetchEtsyPrice(g.listingId);
    if (livePreis) g.preis = livePreis;
  })
);

const techniken = ['Alle', 'Öl', 'Acryl'];
---

<Layout
  title="Gemälde - Sunny Artis | Original Kunstwerke kaufen"
  description="Original Gemälde von Sandra Heise: Öl- und Acrylmalerei auf Leinwand. Handgemalte Unikate, direkt auf Etsy erhältlich."
>
  <section class="section page-header-section">
    <div class="container text-center">
      <span class="section-tag">ORIGINAL KUNSTWERKE</span>
      <h1 class="center-title">Meine Gemälde</h1>
      <p class="section-desc">
        Handgemalte Originale auf Leinwand — jedes Bild ein Unikat. Die verfügbaren Werke sind über meinen Etsy-Shop erhältlich und werden sicher verpackt versendet.
      </p>
    </div>
  </section>

  <section class="section gemaelde-section bg-light">
    <div class="container">
      <div class="filter-wrapper flex-center">
        {techniken.map(t => (
          <button class={`filter-btn${t === 'Alle' ? ' active' : ''}`} data-filter={t === 'Alle' ? 'all' : t.toLowerCase()}>
            {t}
          </button>
        ))}
      </div>

      <div class="grid-3 gemaelde-grid" id="gemaeldeGrid">
        {gemaelde.map(g => (
          <div class={`card gemaelde-card${g.status === 'trocknung' ? ' card-trocknung' : ''}`} data-technik={g.technik}>
            <div class="card-img-wrapper">
              <img src={base + g.image} alt={g.title} />
              <span class="kunstwerk-label">{g.techniklabel}</span>
              {g.status === 'trocknung' ? (
                <span class="badge badge-trocknung card-badge">In Trocknung</span>
              ) : (
                <span class="badge badge-teal card-badge">{g.format}</span>
              )}
            </div>
            <div class="card-content">
              <h3 class="card-title">{g.title}</h3>
              <p class="card-text">{g.beschreibung}</p>
              <div class="card-meta">
                <span class="meta-format">{g.format}</span>
                <span class="meta-preis">{g.preis}</span>
              </div>
              <div class="card-footer">
                <span class="technik-tag">{g.techniklabel}</span>
                {g.status === 'trocknung' ? (
                  <span class="btn btn-disabled btn-sm">Bald verfügbar</span>
                ) : (
                  <a href={g.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-sm">
                    Auf Etsy ansehen
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section auftragskunst-section">
    <div class="container">
      <div class="glass-container auftrags-box">
        <div class="auftrags-content">
          <span class="section-tag">AUFTRAGSGEMÄLDE</span>
          <h2>Wunschgemälde auf Bestellung</h2>
          <p>
            Du hast ein bestimmtes Motiv, eine Farbpalette oder eine persönliche Geschichte, die du auf Leinwand verewigen möchtest? Ich male auch individuelle Auftragsgemälde — vom Porträt bis zur abstrakten Wanddekoration.
          </p>
          <div class="auftrags-actions">
            <a href={`${base}/kontakt`} class="btn btn-primary">Anfrage stellen</a>
            <a href={`${base}/portfolio`} class="btn btn-secondary">Weitere Werke im Portfolio</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header-section {
    padding-bottom: 2rem;
  }

  .section-tag {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    max-width: 600px;
    margin: 0 auto 3rem;
    color: var(--color-text-muted);
  }

  .filter-wrapper {
    gap: 12px;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 9px 22px;
    border-radius: 30px;
    font-family: var(--font-title);
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .filter-btn:hover { border-color: var(--color-teal); color: var(--color-teal); }
  .filter-btn.active {
    background-color: var(--color-teal);
    border-color: var(--color-teal);
    color: white;
    box-shadow: 0 4px 10px rgba(1,170,193,0.2);
  }

  .kunstwerk-label {
    position: absolute;
    bottom: 16px;
    left: 16px;
    z-index: 1;
    background: rgba(255,255,255,0.9);
    padding: 5px 12px;
    border-radius: 20px;
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .card-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
  }

  .badge-trocknung {
    background-color: #6b7280;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: var(--font-title);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-top: 0.25rem;
  }

  .meta-format {
    font-family: var(--font-title);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .meta-preis {
    font-family: var(--font-title);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .technik-tag {
    font-family: var(--font-title);
    font-size: 0.78rem;
    color: var(--color-teal);
    font-weight: 600;
  }

  /* Karte im "In Trocknung"-Status */
  .card-trocknung {
    opacity: 0.8;
  }

  .card-trocknung .card-img-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.08);
    pointer-events: none;
  }

  .btn-disabled {
    background-color: #e5e7eb;
    color: #9ca3af;
    border: none;
    cursor: not-allowed;
    pointer-events: none;
    border-radius: 30px;
    padding: 9px 18px;
    font-family: var(--font-title);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .auftrags-box {
    padding: 4rem 3rem;
  }

  .auftrags-content {
    max-width: 680px;
  }

  .auftrags-content h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .auftrags-content p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .auftrags-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .gemaelde-card { transition: all var(--transition-normal); }
  .gemaelde-card.hidden { display: none; }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.gemaelde-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.getAttribute('data-filter');
      cards.forEach(card => {
        const t = card.getAttribute('data-technik');
        card.classList.toggle('hidden', f !== 'all' && t !== f);
      });
    });
  });
</script>
