---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Metadaten die Etsy nicht liefert (Technik, Format, kuratierte Beschreibung, Fallback-Bild)
const SUPPLEMENTS: Record<string, { technik: string; techniklabel: string; format: string; beschreibung: string; fallbackImage: string }> = {
  "4307467400": {
    technik: "öl", techniklabel: "Öl auf Leinwand", format: "80 × 80 cm",
    beschreibung: "Frauenporträt, zart von Blüten umrahmt — geheimnisvoll und verletzlich zugleich. Preisgekröntes Werk (7. Platz Kunst-Online-Wettbewerb).",
    fallbackImage: `${base}/gemaelde/blutengeist.jpg`,
  },
  "4365612544": {
    technik: "öl", techniklabel: "Öl auf Leinwand", format: "80 × 80 cm",
    beschreibung: "Porträt einer Frau mit Rosen im Haar — leuchtende Farben und ein intensiver Blick verkörpern die Vielfalt weiblicher Gefühle und die Verbundenheit von Mensch und Natur.",
    fallbackImage: `${base}/gemaelde/farbenfroh.jpg`,
  },
  "4354656293": {
    technik: "acryl", techniklabel: "Acryl, Strukturpaste & Blattgold", format: "40 × 50 cm",
    beschreibung: "Ausdrucksstarkes Männerporträt mit edlem Blattgold auf Schwarz und Weiß — metallischer Glanz trifft plastische Tiefe. Stärke und Zerbrechlichkeit in einem Unikat.",
    fallbackImage: `${base}/gemaelde/vergaengliche-staerke.jpg`,
  },
  "4354656511": {
    technik: "acryl", techniklabel: "Acryl, Strukturpaste & Blattgold", format: "40 × 50 cm",
    beschreibung: "Das Folgewerk der Serie — dasselbe kraftvolle Sujet, noch intensiver im Ausdruck. Licht, Schatten und der Glanz des Blattgolds erzählen von Stärke und Vergänglichkeit.",
    fallbackImage: `${base}/gemaelde/vergaengliche-staerke-2.jpg`,
  },
};

// Gemälde die (noch) nicht auf Etsy sind
const MANUAL_GEMAELDE = [
  {
    title: "Silent Crown",
    technik: "öl",
    techniklabel: "Öl auf Leinwand",
    format: "80 × 80 cm",
    preis: "525,00 €",
    beschreibung: "Modernes Frauenporträt mit geschlossenen Augen und aufgesetzter Krone. Farbakzente in Blau, Pink und Türkis vereinen Ruhe und Stärke in einer faszinierenden Komposition.",
    image: `${base}/gemaelde/silent-crown.jpg`,
    status: "trocknung" as const,
    etsy: "",
  },
];

const GEMAELDE = [
  { title: "Blütengeist – Ausdruck einer Seele", preis: "275,00 €", image: `${base}/gemaelde/blutengeist.jpg`, etsy: "https://www.etsy.com/de/listing/4307467400/ol-gemalde-original-frau-mit-blumen", ...SUPPLEMENTS["4307467400"] },
  { title: "Farbenfroh", preis: "525,00 €", image: `${base}/gemaelde/farbenfroh.jpg`, etsy: "https://www.etsy.com/de/listing/4365612544/ol-gemalde-original-farbenfrohe-frau", ...SUPPLEMENTS["4365612544"] },
  { title: "Vergängliche Stärke", preis: "95,00 €", image: `${base}/gemaelde/vergaengliche-staerke.jpg`, etsy: "https://www.etsy.com/de/listing/4354656293/acryl-gemalde-original-vergangliche", ...SUPPLEMENTS["4354656293"] },
  { title: "Vergängliche Stärke 2", preis: "95,00 €", image: `${base}/gemaelde/vergaengliche-staerke-2.jpg`, etsy: "https://www.etsy.com/de/listing/4354656511/acryl-gemalde-original-vergangliche", ...SUPPLEMENTS["4354656511"] },
].map(g => ({ ...g, status: "verfügbar" as const }));

const gemaelde = [...MANUAL_GEMAELDE, ...GEMAELDE];
const techniken = ['Alle', 'Öl', 'Acryl'];

const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/gemaelde`;
const ogImage = `${SITE}/gemaelde/blutengeist.jpg`;

function parsePreis(preis: string): string {
  return preis.replace(/[^\d,]/g, '').replace(',', '.');
}

function parseDimensions(format: string): { width: string; height: string } {
  const m = format.match(/(\d+)\s*[×x]\s*(\d+)/);
  return m ? { width: `${m[1]} cm`, height: `${m[2]} cm` } : { width: format, height: format };
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Gemälde – Original Kunstwerke von Sandra Heise",
  "description": "Handgemalte Originalgemälde auf Leinwand von Sandra Heise: Öl- und Acrylmalerei. Jedes Werk ein Unikat, direkt auf Etsy erhältlich.",
  "url": canonicalUrl,
  "inLanguage": "de",
  "author": {
    "@type": "Person",
    "name": "Sandra Heise",
    "url": SITE
  },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": gemaelde.filter(g => g.status === "verfügbar").length,
    "itemListElement": gemaelde.map((g, i) => {
      const { width, height } = parseDimensions(g.format);
      return {
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "VisualArtwork",
          "name": g.title,
          "description": g.beschreibung,
          "image": g.image.startsWith("http") ? g.image : `${SITE}${g.image.replace(base, "")}`,
          "artMedium": g.techniklabel,
          "artworkSurface": "Leinwand",
          "width": width,
          "height": height,
          "creator": { "@type": "Person", "name": "Sandra Heise" },
          ...(g.status === "verfügbar" && g.etsy ? {
            "offers": {
              "@type": "Offer",
              "price": parsePreis(g.preis),
              "priceCurrency": "EUR",
              "availability": "https://schema.org/InStock",
              "url": g.etsy,
              "seller": { "@type": "Person", "name": "Sandra Heise" }
            }
          } : {})
        }
      };
    })
  }
};
---

<Layout
  title="Gemälde – Original Ölgemälde & Acrylmalerei kaufen | Sunny Artis"
  description="Handgemalte Originalgemälde von Sandra Heise: Öl- und Acrylmalerei auf Leinwand, jedes Werk ein Unikat. Direkt auf Etsy erhältlich und sicher versendet."
  ogImage={ogImage}
  canonical={canonicalUrl}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Gemälde", "item": canonicalUrl }
    ]
  })} />
  <section class="hero-kollektion">
    <div class="container">
      <div class="hero-split">
        <div class="hero-text">
          <span class="section-tag">ORIGINAL KUNSTWERKE</span>
          <h1>Handgemalt.<br/>Einzigartig.</h1>
          <p>Jedes Werk entsteht aus Farbe, Gefühl und Zeit — ein Unikat, das keine Kopie kennt. Verfügbare Gemälde sind direkt auf Etsy erhältlich und werden sicher versendet.</p>
        </div>
        <div class="kollektions-grid">
          <img src={`${base}/gemaelde/blutengeist.jpg`} alt="Blütengeist – Ausdruck einer Seele, Ölgemälde von Sandra Heise" fetchpriority="high" loading="eager" />
          <img src={`${base}/gemaelde/farbenfroh.jpg`} alt="Farbenfroh, Ölgemälde von Sandra Heise" loading="lazy" />
          <img src={`${base}/gemaelde/silent-crown.jpg`} alt="Silent Crown, Ölgemälde von Sandra Heise" loading="lazy" />
          <img src={`${base}/gemaelde/vergaengliche-staerke.jpg`} alt="Vergängliche Stärke, Acrylgemälde von Sandra Heise" loading="lazy" />
          <img src={`${base}/gemaelde/vergaengliche-staerke-2.jpg`} alt="Vergängliche Stärke 2, Acrylgemälde von Sandra Heise" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="section gemaelde-section bg-light">
    <div class="container">
      <h2 class="sr-only">Alle Gemälde</h2>
      <div class="filter-wrapper flex-center">
        {techniken.map(t => (
          <button class={`filter-btn${t === 'Alle' ? ' active' : ''}`} data-filter={t === 'Alle' ? 'all' : t.toLowerCase()}>
            {t}
          </button>
        ))}
      </div>

      <div class="grid-3 gemaelde-grid" id="gemaeldeGrid">
        {gemaelde.map(g => (
          <div class={`card gemaelde-card${g.status === 'trocknung' ? ' card-trocknung' : ''}`} data-technik={g.technik}>
            <div class="card-img-wrapper">
              <img src={g.image} alt={`${g.title} – ${g.techniklabel}, ${g.format}, Sandra Heise`} loading="lazy" />
              <span class="kunstwerk-label">{g.techniklabel}</span>
              {g.status === 'trocknung' ? (
                <span class="badge badge-trocknung card-badge">In Trocknung</span>
              ) : (
                <span class="badge badge-teal card-badge">{g.format}</span>
              )}
            </div>
            <div class="card-content">
              <h3 class="card-title">{g.title}</h3>
              <p class="card-text">{g.beschreibung}</p>
              <div class="card-meta">
                <span class="meta-format">{g.format}</span>
                <span class="meta-preis">{g.preis}</span>
              </div>
              <div class="card-footer">
                <span class="technik-tag">{g.techniklabel}</span>
                {g.status === 'trocknung' ? (
                  <span class="btn btn-disabled btn-sm">Bald verfügbar</span>
                ) : (
                  <a href={g.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-partner btn-sm">
                    Auf Etsy ansehen
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section mehr-section">
    <div class="container text-center">
      <span class="section-tag">MEHR ENTDECKEN</span>
      <h2 class="center-title">Neugierig geworden?</h2>
      <p class="section-desc">Schau dir mein gesamtes Portfolio an oder schreib mir — ich freue mich über jede Nachricht.</p>
      <div class="mehr-actions">
        <a href={`${base}/portfolio`} class="btn btn-primary">Portfolio ansehen</a>
        <a href={`${base}/kontakt`} class="btn btn-secondary">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero-kollektion {
    padding: 5rem 0 4rem;
    background: var(--color-bg-white);
  }

  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text h1 {
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    line-height: 1.1;
    margin: 0.75rem 0 1.25rem;
    color: var(--color-navy);
  }

  .hero-text p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 420px;
  }

  .kollektions-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    grid-template-rows: 190px 190px;
    gap: 6px;
    border-radius: 16px;
    overflow: hidden;
  }

  .kollektions-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }

  .kollektions-grid img:hover { transform: scale(1.04); }
  .kollektions-grid img:first-child { grid-row: 1 / 3; }

  @media (max-width: 768px) {
    .hero-split {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .kollektions-grid {
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 130px 130px;
    }
    .kollektions-grid img:first-child { grid-row: 1; }
  }

  /* Mehr-Sektion */
  .mehr-section {
    background: var(--color-bg-light);
  }

  .mehr-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .section-tag {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    max-width: 600px;
    margin: 0 auto 3rem;
    color: var(--color-text-muted);
  }

  .filter-wrapper {
    gap: 12px;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 9px 22px;
    border-radius: 30px;
    font-family: var(--font-title);
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .filter-btn:hover { border-color: var(--color-teal); color: var(--color-teal); }
  .filter-btn.active {
    background-color: var(--color-teal);
    border-color: var(--color-teal);
    color: white;
    box-shadow: 0 4px 10px rgba(1,170,193,0.2);
  }

  .kunstwerk-label {
    position: absolute;
    bottom: 16px;
    left: 16px;
    z-index: 1;
    background: rgba(255,255,255,0.9);
    padding: 5px 12px;
    border-radius: 20px;
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .card-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
  }

  .badge-trocknung {
    background-color: #6b7280;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: var(--font-title);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-top: 0.25rem;
  }

  .meta-format {
    font-family: var(--font-title);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .meta-preis {
    font-family: var(--font-title);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .technik-tag {
    font-family: var(--font-title);
    font-size: 0.78rem;
    color: var(--color-teal);
    font-weight: 600;
  }

  /* Karte im "In Trocknung"-Status */
  .card-trocknung {
    opacity: 0.8;
  }

  .card-trocknung .card-img-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.08);
    pointer-events: none;
  }

  .btn-disabled {
    background-color: #e5e7eb;
    color: #9ca3af;
    border: none;
    cursor: not-allowed;
    pointer-events: none;
    border-radius: 30px;
    padding: 9px 18px;
    font-family: var(--font-title);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .gemaelde-card { transition: all var(--transition-normal); }
  .gemaelde-card.hidden { display: none; }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.gemaelde-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.getAttribute('data-filter');
      cards.forEach(card => {
        const t = card.getAttribute('data-technik');
        card.classList.toggle('hidden', f !== 'all' && t !== f);
      });
    });
  });
</script>
