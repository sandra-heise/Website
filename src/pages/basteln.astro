---
import Layout from "../layouts/Layout.astro";
import { FREE_DOWNLOADS } from "../config/downloads";

const bestsellers = FREE_DOWNLOADS.filter(d => d.bestseller);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/basteln`;
const ogImage = `${SITE}/basteln/tshirtanker.png`;

// Featured Blog-Beiträge (Basteln & Plotten)
const featuredPosts = [
  {
    title: "Halloween Laterne selber machen – Plotteranleitung",
    date: "11. September 2025",
    category: "Basteln & Plotten",
    excerpt:
      "Mit dieser einfachen Plotteranleitung bastelst du deine eigene Halloween-Laterne — perfekt für herbstliche Abende. Inkl. aller Schritte mit Bildern.",
    image: `${base}/blog/halloween-hero.jpg`,
    gradientClass: "halloween-gradient",
    href: `${base}/blog/halloween-laterne`,
  },
  {
    title: "Ausmalen auf Leinwand: Mit Acrylfarben zum eigenen Kunstwerk",
    date: "20. August 2024",
    category: "Ausmalleinwände",
    excerpt:
      "Ausmalen auf Leinwand mit Acrylfarben und geometrischen Motiven ist weit mehr als ein Hobby — so entsteht aus einer vorgedruckten Leinwand ein echtes Kunstwerk.",
    image: `${base}/blog/ausmalen-leinwand-hero.jpg`,
    gradientClass: "leinwand-gradient",
    href: `${base}/blog/ausmalen-leinwand`,
  },
  {
    title: "Federn zeichnen – Schritt-für-Schritt-Anleitung",
    date: "11. Januar 2024",
    category: "Zeichnen Lernen",
    excerpt:
      "Lerne, wie du mit Bleistift und Kugelschreiber eine realistische Feder zeichnest — von der Skizze bis zum fertigen Detail. Eine einfache Anleitung für Einsteiger.",
    image: `${base}/blog/federn-zeichnen-hero.jpg`,
    gradientClass: "book-gradient",
    href: `${base}/blog/federn-zeichnen`,
  },
];

const etsyImages = [
  { src: `${base}/basteln/tshirtanker.png`,    alt: "Anker-Motiv auf T-Shirt, ausgeschnitten mit Plotter" },
  { src: `${base}/basteln/Baer_thirt.jpg`,     alt: "Bär-Motiv auf T-Shirt mit Plotterdatei" },
  { src: `${base}/basteln/cup_rabbit.jpg`,     alt: "Hase-Motiv auf Becher, gebastelt mit SVG-Datei" },
  { src: `${base}/basteln/Gamer_mit_stil.jpg`, alt: "Gaming-Schriftzug auf Shirt – Plotterdatei von Sunny Artis" },
  { src: `${base}/basteln/Stern.jpg`,       alt: "Weihnachtsstern zum Basteln aus Papier - Giveaway" },
];

// Amazon Empfehlungen (Kompakt für den Fußbereich)
const amazonLinks = [
  {
    name: "Cricut Maker 3 Schneideplotter",
    beschreibung:
      "Der ultimative intelligente Schneideplotter — schneidet über 300 Materialien wie Stoff, Leder, Papier und Smart Materials.",
    link: "https://amzn.to/4aancFE",
    preis: "Top-Empfehlung",
  },
  {
    name: "Plotterfolien (Vinyl-Set)",
    beschreibung:
      "Hochwertiges Farbfolien-Set für präzise Schnitte. Ideal für haltbare Dekorationen auf Glas, Keramik und Holz.",
    link: "https://amzn.to/467iYgm",
    preis: "Bestseller",
  },
  {
    name: "Transparente Folien",
    beschreibung: "Zum Basteln von Laternen ein echtes Must Have!",
    link: "https://amzn.to/4mRdVGS",
    preis: "Zubehör",
  },
  {
    name: "Dickes buntes Papier (Fotokarton)",
    beschreibung:
      "Stabiler Fotokarton (hohe Grammatur) in verschiedenen Farben — perfekt für Faltboxen, Laternen und 3D-Papierkunst.",
    link: "https://amzn.to/3QnnP86",
    preis: "Material",
  },
];
---

<Layout
  title="Basteln & Plotterdateien – SVG-Schnittdateien für Cricut & Silhouette | Sunny Artis"
  description="Basteln mit Plotterdateien von Sandra Heise: SVG, DXF & PNG für Cricut, Silhouette & Co. Kostenlose Freebies zum Download + Anleitungen im Blog."
  canonical={canonicalUrl}
  ogImage={ogImage}
>
  <meta name="keywords" content="Plotterdatei, SVG Schnittdatei, DXF Datei, Cricut Plotterdatei, Silhouette Cameo SVG, kostenlose Plotterdatei, Basteln Anleitung, DIY Plotter, Sunny Artis, Vinyl Plotter, Halloween SVG, Weihnachten Plotterdatei" slot="head" />
  <meta property="og:type" content="website" slot="head" />

  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Basteln & Plotterdateien – Sunny Artis",
    "description": "Plotterdateien als SVG, DXF und PNG für Cricut, Silhouette Cameo und Brother ScanNCut. Kostenlose Freebies zum direkten Download sowie bezahlte Designs auf Etsy.",
    "url": canonicalUrl,
    "inLanguage": "de",
    "image": ogImage,
    "author": { "@type": "Person", "name": "Sandra Heise", "url": SITE },
    "publisher": { "@type": "Organization", "name": "Sunny Artis", "url": SITE },
    "mainEntity": {
      "@type": "ItemList",
      "name": "Kostenlose Bestseller-Plotterdateien",
      "numberOfItems": bestsellers.length,
      "itemListElement": bestsellers.map((d, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "DigitalDocument",
          "name": d.title,
          "description": d.beschreibung,
          "encodingFormat": "application/zip",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
          "url": d.url
        }
      }))
    }
  })} />

  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Basteln & Plotterdateien", "item": canonicalUrl }
    ]
  })} />

  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was ist eine Plotterdatei?",
        "acceptedAnswer": { "@type": "Answer", "text": "Eine Plotterdatei ist eine Vektorgrafik (SVG oder DXF), die von einem Schneideplotter wie Cricut Maker, Silhouette Cameo oder Brother ScanNCut ausgeschnitten wird. Das Gerät folgt den Linien der Datei und schneidet das Motiv präzise aus Papier, Vinyl, Stoff oder anderen Materialien." }
      },
      {
        "@type": "Question",
        "name": "Welche Formate enthalten die Plotterdateien von Sunny Artis?",
        "acceptedAnswer": { "@type": "Answer", "text": "Alle Plotterdateien von Sunny Artis — ob kostenlos oder kostenpflichtig — enthalten vier Formate: SVG (für alle modernen Plotter-Programme), DXF (für ältere Software), PNG (als transparente Bilddatei) und JPG (als Vorschau). Du bekommst also immer alle Varianten in einer ZIP-Datei." }
      },
      {
        "@type": "Question",
        "name": "Für welche Plotter-Programme sind die SVG-Dateien geeignet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Die SVG-Schnittdateien funktionieren mit allen gängigen Programmen: Cricut Design Space, Silhouette Studio, Brother Canvas Workspace, Inkscape und viele mehr. DXF-Dateien sind zusätzlich kompatibel mit älteren Plotter-Softwareversionen." }
      },
      {
        "@type": "Question",
        "name": "Wo kann ich die kostenpflichtigen Plotterdateien kaufen?",
        "acceptedAnswer": { "@type": "Answer", "text": "Die bezahlten Plotterdateien von Sunny Artis sind im Etsy-Shop von Sandra Heise erhältlich. Nach dem Kauf steht der Download sofort als digitale Datei bereit — kein Versand, kein Warten." }
      },
      {
        "@type": "Question",
        "name": "Darf ich die Dateien für selbstgemachte Produkte nutzen, die ich verkaufe?",
        "acceptedAnswer": { "@type": "Answer", "text": "Die kostenlosen Freebies sind ausschließlich für den privaten Gebrauch. Für kommerzielle Nutzung (z. B. selbst hergestellte Produkte verkaufen) benötigst du eine der kostenpflichtigen Lizenzdateien aus dem Etsy-Shop." }
      }
    ]
  })} />

  <!-- Hero Bereich -->
  <section class="hero-section text-center">
    <div class="container hero-container">

      <h1 class="hero-title">Basteln & Plotterdateien</h1>
      <p class="hero-desc">
        SVG- und DXF-Schnittdateien für Cricut, Silhouette & Co. — plus kostenlose Freebies zum direkten Download und Schritt-für-Schritt-Bastelanleitungen.
      </p>
      <div class="hero-cta-buttons">
        <a href="#etsy-shop" class="btn btn-primary">Etsy Plotterdateien</a>
        <a href="#downloads-freebies" class="btn btn-secondary"
          >Kostenlose Vorlagen</a
        >
      </div>
    </div>
  </section>

  <!-- Etsy Shop Sektion -->
  <section id="etsy-shop" class="section etsy-section">
    <div class="container">
      <div class="section-header text-center">

        <h2>Meine Plotterdateien auf Etsy</h2>
        <p class="section-desc">
          Alle Schnittmuster und SVG-Dateien sind präzise gezeichnet und
          optimiert für gängige Hobbyplotter wie Silhouette Cameo, Cricut Maker
          oder Brother ScanNCut.
        </p>
      </div>

      <!-- Bildercollage -->
      <div class="etsy-collage">
        <div class="etsy-collage-main">
          <img src={etsyImages[0].src} alt={etsyImages[0].alt} loading="eager" fetchpriority="high" />
        </div>
        <div class="etsy-collage-stack">
          <img src={etsyImages[1].src} alt={etsyImages[1].alt} loading="lazy" />
          <img src={etsyImages[2].src} alt={etsyImages[2].alt} loading="lazy" />
        </div>
        <div class="etsy-collage-bottom">
          <img src={etsyImages[3].src} alt={etsyImages[3].alt} loading="lazy" />
          <img src={etsyImages[4].src} alt={etsyImages[4].alt} loading="lazy" />
        </div>
      </div>

      <!-- Zentraler Button zum Etsy Shop -->
      <div class="text-center etsy-cta-row">
        <p class="etsy-cta-text">
          Bequem herunterladen und sofort loslegen. Alle Dateien sind in meinem
          Etsy-Shop als digitaler Sofortdownload verfügbar.
        </p>
        <a
          href="https://www.etsy.com/shop/SunnyArtis?section_id=45759329"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-partner btn-lg etsy-shop-btn"
        >
          <span>Sunny Artis Plotterdateien auf Etsy kaufen</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
        </a>
      </div>
    </div>
  </section>

  <!-- Bestseller-Slider Sektion -->
  <section id="downloads-freebies" class="section bg-light slider-section">
    <div class="container">
      <div class="section-header text-center">

        <h2>Beliebteste Plotterdateien</h2>
        <p class="section-desc">
          Die meistgenutzten kostenlosen Designs — direkt zum Download, ohne Anmeldung.
        </p>
      </div>

      <div class="slider-wrapper">
        <button class="slider-arrow slider-prev" aria-label="Zurück" id="sliderPrev">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="slider-track" id="sliderTrack">
          {bestsellers.map((dl) => (
            <div class="slider-card">
              <div class="slider-img">
                {dl.vorschau
                  ? <img src={`${base}${dl.vorschau}`} alt={`${dl.title} – kostenlose Plotterdatei`} loading="lazy" />
                  : <div class="slider-placeholder"><span>{dl.kategorie}</span></div>
                }
                <span class="slider-kategorie-badge">{dl.kategorie}</span>
              </div>
              <div class="slider-card-content">
                <h3 class="slider-card-title">{dl.title}</h3>
                <div class="slider-card-actions">
                  <a href={dl.url} download class="btn btn-accent btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Herunterladen
                  </a>
                  {dl.blogPost && (
                    <a href={`${base}${dl.blogPost}`} class="slider-anleitung-link">Anleitung →</a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>

        <button class="slider-arrow slider-next" aria-label="Weiter" id="sliderNext">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Auffälliger Download-CTA -->
  <section class="download-cta-section">
    <div class="container">
      <div class="download-cta-inner">
        <div class="download-cta-deco">
          <span class="cta-big-number">{FREE_DOWNLOADS.length}</span>
          <span class="cta-big-label">kostenlose<br/>Designs</span>
        </div>
        <div class="download-cta-text">
          <span class="cta-kicker">Komplett gratis · Sofort verfügbar · Kein Konto</span>
          <h2 class="cta-headline">SVG · DXF · PNG · JPG —<br/>alle Formate, eine Datei.</h2>
          <p class="cta-body">Halloween, Weihnachten, Ostern, Herbst und mehr — die gesamte Bibliothek wartet auf dich.</p>
          <a href={`${base}/downloads`} class="btn cta-btn">
            Alle Downloads ansehen
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DIY-Blog Beiträge Sektion -->
  <section class="section blog-section">
    <div class="container">
      <div class="section-header text-center">

        <h2>Schritt-für-Schritt-Anleitungen</h2>
        <p class="section-desc">
          Praktische Tipps, genaue Anleitungen und Inspirationen rund um das
          Thema Basteln und Plotten findest du in meinem Blog.
        </p>
      </div>

      <div class="grid-3 blog-grid">
        {
          featuredPosts.map((post) => (
            <article class="card blog-card">
              <div class="card-img-wrapper">
                {post.image ? (
                  <img src={post.image} alt={post.title} loading="lazy" />
                ) : (
                  <div
                    class={`simulated-image-placeholder ${post.gradientClass}`}
                  >
                    <span>{post.category}</span>
                  </div>
                )}
                <span class="badge badge-navy card-badge">{post.date}</span>
              </div>
              <div class="card-content">
                <span class="blog-post-category">{post.category}</span>
                <h3 class="card-title blog-post-title">{post.title}</h3>
                <p class="card-text">{post.excerpt}</p>
                <div class="card-footer">
                  <a href={post.href} class="read-more-link">
                    <span>Anleitung lesen</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                      </>
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Amazon Empfehlungen (Kompakt im Fußbereich) -->
  <section class="section bg-light compact-material-section">
    <div class="container">
      <div class="section-header text-center">

        <h2>Meine Plotter-Empfehlungen</h2>
        <p class="section-desc">
          Diese Geräte, Werkzeuge und Folien verwende ich in meiner eigenen
          Bastelwerkstatt.
        </p>
      </div>

      <div class="affiliate-hinweis-banner">
        <strong>* Affiliate-Hinweis:</strong> Die mit einem Sternchen (*) gekennzeichneten
        Links sind Amazon-Partnerlinks. Wenn du darüber kaufst, erhalte ich eine kleine
        Provision. Der Preis ändert sich für dich natürlich nicht. Ich empfehle nur
        Produkte, die ich selbst besitze und regelmäßig nutze.
      </div>

      <div class="grid-2 material-grid">
        {
          amazonLinks.map((item) => (
            <div class="material-card card">
              <div class="card-content">
                <div class="material-card-header">
                  <h3 class="material-title">{item.name}</h3>
                  <span class="material-price">{item.preis}</span>
                </div>
                <p class="card-text">{item.beschreibung}</p>
                <a
                  href={item.link}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="btn btn-outline-dark btn-sm align-self-start"
                >
                  Auf Amazon ansehen *
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  const track = document.getElementById('sliderTrack') as HTMLElement;
  const prev = document.getElementById('sliderPrev') as HTMLButtonElement;
  const next = document.getElementById('sliderNext') as HTMLButtonElement;
  if (track && prev && next) {
    const scrollAmount = () => {
      const card = track.querySelector('.slider-card') as HTMLElement;
      return card ? card.offsetWidth + 20 : 280;
    };
    prev.addEventListener('click', () => track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: scrollAmount(), behavior: 'smooth' }));
  }
</script>

<style>
  /* Header & Hero */
  .hero-section {
    padding: 7rem 0 5rem;
    background: linear-gradient(135deg, #f7fdfe 0%, #edf8fa 50%, #e0f4f7 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(
      circle,
      rgba(1, 170, 193, 0.06) 0%,
      rgba(255, 255, 255, 0) 70%
    );
    pointer-events: none;
  }

  .hero-container {
    max-width: 800px;
    position: relative;
    z-index: 2;
  }


  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.2rem);
    line-height: 1.15;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .hero-desc {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .hero-cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Section Styles */
  .section-header {
    margin-bottom: 3.5rem;
  }

  .section-header h2 {
    font-size: 2.2rem;
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .section-desc {
    max-width: 650px;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .section-action-row {
    margin-top: 3.5rem;
  }

  /* Etsy Sektion */
  .etsy-section {
    background-color: var(--color-bg-white);
  }

  /* Bildercollage */
  .etsy-collage {
    display: grid;
    grid-template-columns: 3fr 2fr;
    grid-template-rows: auto auto;
    gap: 12px;
    margin-bottom: 2.5rem;
    border-radius: 20px;
    overflow: hidden;
  }

  .etsy-collage-main {
    grid-row: 1 / 2;
    grid-column: 1 / 2;
    height: 560px;
    overflow: hidden;
  }

  .etsy-collage-stack {
    grid-row: 1 / 2;
    grid-column: 2 / 3;
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 560px;
  }

  .etsy-collage-stack > * {
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }

  .etsy-collage-bottom {
    grid-row: 2 / 3;
    grid-column: 1 / 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .etsy-collage img,
  .etsy-collage-stack img,
  .etsy-collage-bottom img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    border-radius: 12px;
  }

  .etsy-collage-main img {
    border-radius: 12px;
    height: 100%;
  }

  .etsy-collage-stack img {
    border-radius: 10px;
    height: 100%;
  }

  .etsy-collage-bottom img {
    aspect-ratio: 16/7;
    border-radius: 10px;
  }

  .etsy-collage img:hover,
  .etsy-collage-stack img:hover,
  .etsy-collage-bottom img:hover {
    transform: scale(1.03);
  }

  @media (max-width: 600px) {
    .etsy-collage {
      grid-template-columns: 1fr 1fr;
    }
    .etsy-collage-main {
      grid-column: 1 / 3;
    }
    .etsy-collage-stack {
      grid-column: 1 / 3;
      flex-direction: row;
    }
    .etsy-collage-bottom {
      grid-column: 1 / 3;
    }
  }

  .etsy-cta-row {
    max-width: 650px;
    margin: 3rem auto 0;
  }

  .etsy-cta-text {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .btn-lg {
    padding: 14px 36px;
    font-size: 1.05rem;
  }

  .etsy-shop-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
  }

  .etsy-shop-btn svg {
    transition: transform var(--transition-fast);
  }

  .etsy-shop-btn:hover svg {
    transform: translateX(5px);
  }


  /* Downloads Sektion */
  .downloads-section {
