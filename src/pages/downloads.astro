---
import Layout from '../layouts/Layout.astro';
import { FREE_DOWNLOADS } from '../config/downloads';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/downloads`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Kostenlose Plotterdateien – Sunny Artis",
  "description": "Kostenlose SVG-Plotterdateien von Sandra Heise: Laternen, Dekorationen und mehr. Direkt herunterladen, ohne Anmeldung.",
  "url": canonicalUrl,
  "inLanguage": "de",
  "author": { "@type": "Person", "name": "Sandra Heise", "url": SITE },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": FREE_DOWNLOADS.length,
    "itemListElement": FREE_DOWNLOADS.map((d, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "SoftwareApplication",
        "applicationCategory": "DesignApplication",
        "name": d.title,
        "description": d.beschreibung,
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
        "downloadUrl": d.url,
        "fileFormat": d.format
      }
    }))
  }
};
---

<Layout
  title="Kostenlose Plotterdateien zum Download | Sunny Artis"
  description="Kostenlose SVG-Plotterdateien von Sandra Heise — Laternen, Dekorationen und mehr. Direkt herunterladen, ohne Anmeldung, ohne Kosten."
  canonical={canonicalUrl}
>
  <meta name="keywords" content="Kostenlose Plotterdatei, SVG Download kostenlos, Plotterdatei gratis, Halloween Laterne SVG, Sunny Artis Download" slot="head" />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Kostenlose Downloads", "item": canonicalUrl }
    ]
  })} />

  <section class="section page-header-section">
    <div class="container text-center">
      <span class="section-tag">GRATIS</span>
      <h1 class="center-title">Kostenlose Plotterdateien</h1>
      <p class="section-desc">
        Handverlesene SVG-Dateien zum sofortigen Download — kostenlos, ohne Anmeldung. Einfach herunterladen, in dein Schneideprogramm laden und loslegen.
      </p>
    </div>
  </section>

  <section class="section bg-light downloads-section">
    <div class="container">
      <div class="downloads-grid">
        {FREE_DOWNLOADS.map(d => (
          <article class="card download-card">
            <div class="card-img-wrapper">
              {d.vorschau
                ? <img src={`${base}${d.vorschau}`} alt={`${d.title} – Plotterdatei Vorschau`} loading="lazy" />
                : <div class="download-placeholder"><span>{d.kategorie}</span></div>
              }
              <span class="badge badge-gratis card-badge">Kostenlos</span>
            </div>
            <div class="card-content">
              <span class="download-kategorie">{d.kategorie}</span>
              <h2 class="card-title">{d.title}</h2>
              <p class="card-text">{d.beschreibung}</p>
              <div class="download-meta">
                <span class="download-format">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                  {d.format}
                </span>
              </div>
              <div class="card-footer download-footer">
                <a href={d.url} download class="btn btn-accent btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                  Herunterladen
                </a>
                {d.blogPost && (
                  <a href={`${base}${d.blogPost}`} class="anleitung-link">
                    Zur Anleitung →
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      {FREE_DOWNLOADS.length === 0 && (
        <p class="text-center" style="color: var(--color-text-muted); padding: 4rem 0;">
          Bald verfügbar — schau bald wieder rein!
        </p>
      )}
    </div>
  </section>

  <section class="section hinweis-section">
    <div class="container">
      <div class="glass-container hinweis-box">
        <div class="hinweis-icon">📋</div>
        <div>
          <h2>Nutzungshinweis</h2>
          <p>Die Dateien sind für den <strong>privaten, nicht-kommerziellen Gebrauch</strong> freigegeben. Du darfst sie für dich selbst nutzen, ausschneiden und basteln — eine Weiterverteilung oder der kommerzielle Einsatz ist nicht gestattet. Viel Spaß beim Basteln!</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-tag {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    max-width: 600px;
    margin: 0 auto;
    color: var(--color-text-muted);
  }

  .downloads-section { padding-bottom: 5rem; }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .download-card { height: 100%; }

  .download-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1c0a00 0%, #ff6600 60%, #f59e0b 100%);
    font-family: var(--font-title);
    font-weight: 600;
    color: white;
    font-size: 0.95rem;
  }

  .badge-gratis {
    background: #16a34a;
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: var(--font-title);
  }

  .download-kategorie {
    font-family: var(--font-title);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: block;
    margin-bottom: 0.4rem;
  }

  .download-meta {
    margin-bottom: 1.25rem;
  }

  .download-format {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-title);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-bg-light);
    border: 1px solid var(--color-border);
    padding: 3px 10px;
    border-radius: 20px;
  }

  .download-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-accent svg {
    vertical-align: middle;
    margin-right: 4px;
  }

  .anleitung-link {
    font-family: var(--font-title);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: color var(--transition-fast);
  }

  .anleitung-link:hover { color: var(--color-navy); }

  .hinweis-section { background: var(--color-bg-white); padding: 3rem 0 4rem; }

  .hinweis-box {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem 2.5rem;
  }

  .hinweis-icon { font-size: 2rem; flex-shrink: 0; line-height: 1; margin-top: 2px; }

  .hinweis-box h2 { font-size: 1.1rem; color: var(--color-navy); margin: 0 0 0.5rem; }

  .hinweis-box p { color: var(--color-text-muted); line-height: 1.7; margin: 0; font-size: 0.95rem; }

  @media (max-width: 600px) {
    .hinweis-box { flex-direction: column; gap: 1rem; padding: 1.5rem; }
  }
</style>
