---
import Layout from '../layouts/Layout.astro';
import { FREE_DOWNLOADS } from '../config/downloads';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/downloads`;

// Bestseller zuerst, dann Rest in Originalreihenfolge
const sorted = [...FREE_DOWNLOADS].sort((a, b) => (b.bestseller ? 1 : 0) - (a.bestseller ? 1 : 0));

// Eindeutige Kategorien extrahieren (aus sortierter Liste)
const categories = [...new Set(sorted.map(d => d.kategorie))];

const ogImage = `${SITE}/blog/halloween-hero.jpg`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Kostenlose Plotterdateien – Sunny Artis",
  "description": `${FREE_DOWNLOADS.length} kostenlose SVG-Plotterdateien von Sandra Heise: Halloween, Weihnachten, Ostern, Herbst und mehr. Direkt herunterladen, ohne Anmeldung.`,
  "url": canonicalUrl,
  "inLanguage": "de",
  "datePublished": "2025-01-01",
  "dateModified": "2026-01-01",
  "image": ogImage,
  "author": { "@type": "Person", "name": "Sandra Heise", "url": SITE },
  "publisher": { "@type": "Organization", "name": "Sunny Artis", "url": SITE },
  "mainEntity": {
    "@type": "ItemList",
    "name": "Kostenlose Plotterdateien von Sunny Artis",
    "numberOfItems": FREE_DOWNLOADS.length,
    "itemListElement": sorted.map((d, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "DigitalDocument",
        "name": d.title,
        "description": d.beschreibung,
        "encodingFormat": "application/zip",
        "keywords": `Plotterdatei, ${d.kategorie}, SVG, DXF, PNG, kostenlos, Freebie`,
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" },
        "url": d.url,
        "inLanguage": "de",
        "author": { "@type": "Person", "name": "Sandra Heise" }
      }
    }))
  }
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was ist eine Plotterdatei?",
      "acceptedAnswer": { "@type": "Answer", "text": "Eine Plotterdatei ist eine Vektorgrafik (meist SVG oder DXF), die von einem Schneideplotter wie Cricut, Silhouette oder Brother gelesen wird. Der Plotter schneidet das Motiv aus Papier, Vinyl oder anderen Materialien aus." }
    },
    {
      "@type": "Question",
      "name": "Welche Formate sind in den Download-Paketen enthalten?",
      "acceptedAnswer": { "@type": "Answer", "text": "Jede kostenlose Plotterdatei von Sunny Artis enthält vier Formate: SVG (für Cricut, Silhouette & Co.), DXF (für ältere Plotter-Programme), PNG (als Druckvorlage oder Referenz) und JPG (als Vorschaubild)." }
    },
    {
      "@type": "Question",
      "name": "Welches Programm brauche ich, um SVG-Dateien zu öffnen?",
      "acceptedAnswer": { "@type": "Answer", "text": "SVG-Dateien öffnest du in deiner Plotter-Software: Cricut Design Space, Silhouette Studio, Brother Canvas Workspace oder auch Inkscape (kostenlos). Für DXF-Dateien eignen sich zusätzlich AutoCAD-basierte Programme." }
    },
    {
      "@type": "Question",
      "name": "Sind die Plotterdateien wirklich kostenlos?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, alle Dateien auf dieser Seite sind gratis und ohne Anmeldung sofort herunterladbar. Sie sind für den privaten, nicht-kommerziellen Gebrauch freigegeben." }
    },
    {
      "@type": "Question",
      "name": "Darf ich die Dateien kommerziell nutzen oder weiterverkaufen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Nein. Die kostenlosen Plotterdateien sind ausschließlich für den privaten Gebrauch bestimmt. Weiterverkauf, kommerzielle Nutzung oder Weitergabe ist nicht gestattet. Für kommerzielle Lizenzen kontaktiere bitte Sunny Artis direkt." }
    },
    {
      "@type": "Question",
      "name": "Wie lade ich eine Plotterdatei herunter?",
      "acceptedAnswer": { "@type": "Answer", "text": "Klicke einfach auf den gelben 'Herunterladen'-Button unter der gewünschten Datei. Der Download startet sofort als ZIP-Archiv — kein Konto, keine E-Mail-Eingabe nötig." }
    }
  ]
};
---

<Layout
  title={`${FREE_DOWNLOADS.length} kostenlose Plotterdateien zum Download | Sunny Artis`}
  description="Kostenlose SVG-Plotterdateien von Sandra Heise — Halloween, Weihnachten, Ostern, Herbst & mehr. Sofort herunterladen, ohne Anmeldung, als SVG · DXF · PNG · JPG."
  canonical={canonicalUrl}
  ogImage={ogImage}
>
  <meta name="keywords" content="Kostenlose Plotterdatei, SVG Download kostenlos, Plotterdatei gratis, Halloween SVG, Weihnachten Plotterdatei, Ostern SVG, Herbst Plotterdatei, Feiertage SVG, Herz Silhouette, Wichtel Plotterdatei, Sunny Artis Freebie, Cricut SVG, Silhouette SVG" slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:image" content={ogImage} slot="head" />
  <meta property="og:image:alt" content="Kostenlose Plotterdateien von Sunny Artis" slot="head" />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Kostenlose Downloads", "item": canonicalUrl }
    ]
  })} />

  <section class="section page-header-section">
    <div class="container text-center">
      <span class="section-tag">GRATIS</span>
      <h1 class="center-title">Kostenlose Plotterdateien</h1>
      <p class="section-desc">
        Handverlesene Dateien zum sofortigen Download — kostenlos, ohne Anmeldung. Einfach herunterladen, in dein Schneideprogramm laden und loslegen.
      </p>
      <p class="section-format-hint">Alle Dateien enthalten: SVG · PNG · DXF · JPG</p>
    </div>
  </section>

  <!-- Kategorie-Filter -->
  {categories.length > 0 && (
    <section class="filter-section">
      <div class="container text-center">
        <div class="filter-buttons" id="filter-buttons">
          <button class="btn-filter active" data-category="all" aria-pressed="true">Alle</button>
          {categories.map(cat => (
            <button class="btn-filter" data-category={cat} aria-pressed="false">{cat}</button>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section bg-light downloads-section">
    <div class="container">
      <div class="downloads-grid">
        {sorted.map((d, i) => (
          <article class="card download-card" data-category={d.kategorie}>
            <div class="card-img-wrapper">
              {d.vorschau
                ? <img src={`${base}${d.vorschau}`} alt={`${d.title} – kostenlose Plotterdatei als SVG, DXF, PNG`} loading={i < 6 ? "eager" : "lazy"} fetchpriority={i < 3 ? "high" : "auto"} />
                : <div class="download-placeholder"><span>{d.kategorie}</span></div>
              }
              {d.bestseller && <span class="badge badge-bestseller">Bestseller</span>}
            </div>
            <div class="card-content">
              <span class="download-kategorie">{d.kategorie}</span>
              <h3 class="card-title">{d.title}</h3>
              <p class="card-desc">{d.beschreibung}</p>
              <div class="card-footer download-footer">
                <a href={d.url} download class="btn btn-accent btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                  Herunterladen
                </a>
                {d.blogPost && (
                  <a href={`${base}${d.blogPost}`} class="anleitung-link">
                    Anleitung →
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      {FREE_DOWNLOADS.length === 0 && (
        <p class="text-center" style="color: var(--color-text-muted); padding: 4rem 0;">
          Bald verfügbar — schau bald wieder rein!
        </p>
      )}
    </div>
  </section>

  <section class="section hinweis-section">
    <div class="container">
      <div class="glass-container hinweis-box">
        <div class="hinweis-icon">📋</div>
        <div>
          <h2>Nutzungshinweis</h2>
          <p>Die Dateien sind für den <strong>privaten, nicht-kommerziellen Gebrauch</strong> freigegeben. Du darfst sie für dich selbst nutzen, ausschneiden und basteln — eine Weiterverteilung oder der kommerzielle Einsatz ist nicht gestattet. Viel Spaß beim Basteln!</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('.btn-filter');
  const cards = document.querySelectorAll('.download-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');

      const selectedCat = btn.getAttribute('data-category');

      cards.forEach(card => {
        const cardCat = card.getAttribute('data-category');
        const cardElement = card as HTMLElement;

        if (selectedCat === 'all' || cardCat === selectedCat) {
          cardElement.style.display = 'flex';
          // Sanftes Einblenden
          setTimeout(() => {
            cardElement.style.opacity = '1';
            cardElement.style.transform = 'translateY(0)';
          }, 10);
        } else {
          // Sanftes Ausblenden
          cardElement.style.opacity = '0';
          cardElement.style.transform = 'translateY(12px)';
          setTimeout(() => {
            cardElement.style.display = 'none';
          }, 200); // Entspricht der Transitionsdauer
        }
      });
    });
  });
</script>

<style>
  .section-tag {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    max-width: 600px;
    margin: 0 auto 0.5rem;
    color: var(--color-text-muted);
  }

  .section-format-hint {
    font-family: var(--font-title);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
  }

  /* Filter-Bar */
  .filter-section {
    padding: 0 0 3rem;
    background-color: var(--color-bg-white);
  }

  .filter-buttons {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-filter {
    padding: 8px 24px;
    font-family: var(--font-title);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 30px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-light);
    color: var(--color-navy);
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .btn-filter:hover {
    border-color: var(--color-teal);
    color: var(--color-teal);
    transform: translateY(-1px);
  }

  .btn-filter.active {
    background-color: var(--color-teal);
    border-color: var(--color-teal);
    color: white;
    box-shadow: 0 4px 12px rgba(1, 170, 193, 0.15);
  }

  /* Downloads-Grid */
  .downloads-section { padding-bottom: 5rem; }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .download-card {
    height: 100%;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
    opacity: 1;
    transform: translateY(0);
  }

  .download-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1c0a00 0%, #ff6600 60%, #f59e0b 100%);
    font-family: var(--font-title);
    font-weight: 600;
    color: white;
    font-size: 0.95rem;
  }

  .badge-bestseller {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(186, 214, 218, 0.55);
    color: #046878;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    font-family: var(--font-title);
    letter-spacing: 0.04em;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(1, 170, 193, 0.2);
  }

  .card-content {
    padding: 16px 20px 18px;
  }

  .card-title {
    font-size: 1rem;
    margin-bottom: 0.4rem;
    margin-top: 0.25rem;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .download-kategorie {
    font-family: var(--font-title);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .download-format {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-title);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-bg-light);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .download-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-accent svg {
    vertical-align: middle;
    margin-right: 4px;
  }

  .anleitung-link {
    font-family: var(--font-title);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-teal);
    transition: color var(--transition-fast);
  }

  .anleitung-link:hover { color: var(--color-navy); }

  .hinweis-section { background: var(--color-bg-white); padding: 3rem 0 4rem; }

  .hinweis-box {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem 2.5rem;
  }

  .hinweis-icon { font-size: 2rem; flex-shrink: 0; line-height: 1; margin-top: 2px; }

  .hinweis-box h2 { font-size: 1.1rem; color: var(--color-navy); margin: 0 0 0.5rem; }

  .hinweis-box p { color: var(--color-text-muted); line-height: 1.7; margin: 0; font-size: 0.95rem; }

  @media (max-width: 600px) {
    .hinweis-box { flex-direction: column; gap: 1rem; padding: 1.5rem; }
  }
</style>
