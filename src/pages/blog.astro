---
import Layout from '../layouts/Layout.astro';
import { FREE_DOWNLOADS } from '../config/downloads';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const blogPosts = [
  {
    id: 1,
    title: "Das sind wir – Das Sunny Artis Team",
    date: "15. September 2025",
    category: "Über uns",
    excerpt: "Von der ersten Bleistiftzeichnung zum eigenen Kunstlabel: Sandra Heise und Harald Wißmach stellen sich vor — und erzählen, wie aus einer Leidenschaft Sunny Artis wurde.",
    image: `${base}/blog/das-sind-wir-hero.jpg`,
    gradientClass: "team-gradient",
    href: `${base}/blog/das-sind-wir`,
  },
  {
    id: 2,
    title: "Halloween Laterne selber machen – Plotteranleitung",
    date: "11. September 2025",
    category: "Basteln & Plotten",
    excerpt: "Mit dieser einfachen Plotteranleitung bastelst du deine eigene Halloween-Laterne — perfekt für herbstliche Abende. Inkl. aller Schritte mit Bildern.",
    image: `${base}/blog/halloween-hero.jpg`,
    gradientClass: "halloween-gradient",
    href: `${base}/blog/halloween-laterne`,
  },
  {
    id: 3,
    title: "Ausmalen auf Leinwand: Mit Acrylfarben zum eigenen Kunstwerk",
    date: "20. August 2024",
    category: "Ausmalleinwände",
    excerpt: "Ausmalen auf Leinwand mit Acrylfarben und geometrischen Motiven ist weit mehr als ein Hobby — so entsteht aus einer vorgedruckten Leinwand ein echtes Kunstwerk.",
    image: `${base}/blog/ausmalen-leinwand-hero.jpg`,
    gradientClass: "leinwand-gradient",
    href: `${base}/blog/ausmalen-leinwand`,
  },
  {
    id: 4,
    title: "Ein Wochenende voller Kreativität auf dem Kreativmarkt Magdeburg",
    date: "22. Januar 2024",
    category: "Events & Messen",
    excerpt: "Unser viertes Jahr als Aussteller auf dem Kreativmarkt Magdeburg — Begegnungen, Inspiration und handgemachte Produkte. Ein Rückblick auf ein besonderes Wochenende.",
    image: `${base}/blog/kreativmarkt-hero.png`,
    gradientClass: "markt-gradient",
    href: `${base}/blog/kreativmarkt-magdeburg`,
  },
  {
    id: 5,
    title: "Federn zeichnen – Schritt-für-Schritt-Anleitung",
    date: "11. Januar 2024",
    category: "Zeichnen Lernen",
    excerpt: "Lerne, wie du mit Bleistift und Kugelschreiber eine realistische Feder zeichnest — von der Skizze bis zum fertigen Detail. Eine einfache Anleitung für Einsteiger.",
    image: `${base}/blog/federn-zeichnen-hero.jpg`,
    gradientClass: "book-gradient",
    href: `${base}/blog/federn-zeichnen`,
  },
];
---

<Layout title="DIY-Blog - Sunny Artis | Bastel- & Zeichenanleitungen" description="Schritt-für-Schritt-Anleitungen zum Zeichnen, Basteln und Arbeiten mit Plotterdateien. Lerne neue kreative Hobbys im Blog von Sandra Heise.">
  <section class="section page-header-section">
    <div class="container text-center">
      <span class="section-tag">KREATIV-BLOG</span>
      <h1 class="center-title">Mein kreativer Ratgeber</h1>
      <p class="section-desc">
        Ich teile meine Leidenschaft gerne mit anderen. In meinem Blog findest du praktische Anleitungen, Tipps fürs Zeichnen und kreative Ideen für deine eigenen DIY-Projekte.
      </p>
    </div>
  </section>

  <!-- Blog Posts List -->
  <section class="section blog-list-section bg-light">
    <div class="container">
      <div class="grid-3 blog-grid">
        {blogPosts.map(post => (
          <article class="card blog-card">
            <div class="card-img-wrapper">
              {post.image
                ? <img src={post.image} alt={post.title} loading="lazy" />
                : <div class={`simulated-image ${post.gradientClass}`}><span>{post.category}</span></div>
              }
              <span class="badge badge-navy card-badge">{post.date}</span>
            </div>
            <div class="card-content">
              <span class="blog-category">{post.category}</span>
              <h3 class="card-title blog-post-title">{post.title}</h3>
              <p class="card-text">{post.excerpt}</p>
              <div class="card-footer">
                <a href={post.href} class="read-more-link">
                  <span>Weiterlesen</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Kostenlose Downloads -->
  {FREE_DOWNLOADS.length > 0 && (
    <section class="section downloads-teaser">
      <div class="container">
        <div class="downloads-header">
          <div>
            <span class="section-tag">GRATIS</span>
            <h2 class="downloads-title">Kostenlose Plotterdateien</h2>
            <p class="downloads-desc">Zu manchen Anleitungen gibt es die passende Datei gleich dazu — kostenlos, ohne Anmeldung.</p>
          </div>
          <a href={`${base}/downloads`} class="btn btn-secondary downloads-alle-btn">Alle Downloads</a>
        </div>
        <div class="downloads-liste">
          {FREE_DOWNLOADS.map(d => (
            <div class="download-row">
              {d.vorschau && (
                <img src={`${base}${d.vorschau}`} alt={d.title} class="download-thumb" loading="lazy" />
              )}
              <div class="download-info">
                <span class="download-kat">{d.kategorie}</span>
                <strong class="download-name">{d.title}</strong>
                <span class="download-fmt">{d.format}</span>
              </div>
              <div class="download-actions">
                {d.blogPost && (
                  <a href={`${base}${d.blogPost}`} class="anleitung-link">Anleitung</a>
                )}
                <a href={d.url} download class="btn btn-accent btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                  Download
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter Teaser (Static / Info) -->
  <section class="section newsletter-teaser">
    <div class="container">
      <div class="glass-container newsletter-box text-center">
        <h2>Bleibe kreativ auf dem Laufenden</h2>
        <p>
          Verpasse keine neuen Zeichnungen, DIY-Anleitungen oder Angebote. Folge mir am besten auf meinen Social-Media-Kanälen, wo ich regelmäßig Einblicke in meine Arbeit gebe.
        </p>
        <div class="social-buttons flex-center">
          <a href="https://www.instagram.com/sunny_artis" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Instagram folgen</a>
          <a href="https://www.youtube.com/@sunny_artis" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">YouTube abonnieren</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-category {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-teal);
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
  }

  .blog-post-title {
    font-size: 1.2rem;
    line-height: 1.4;
    margin-bottom: 12px;
  }

  .read-more-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-teal);
    transition: all var(--transition-fast);
  }

  .read-more-link:hover {
    color: var(--color-navy);
  }

  .read-more-link svg {
    transition: transform var(--transition-fast);
  }

  .read-more-link:hover svg {
    transform: translateX(4px);
  }

  /* Downloads Teaser */
  .downloads-teaser { background: var(--color-bg-white); }

  .downloads-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .downloads-title {
    font-size: 1.6rem;
    color: var(--color-navy);
    margin: 0.4rem 0 0.5rem;
  }

  .downloads-desc {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  .downloads-alle-btn { flex-shrink: 0; }

  .downloads-liste {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-bg-light);
  }

  .download-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-fast);
  }

  .download-row:last-child { border-bottom: none; }
  .download-row:hover { background: var(--color-bg-white); }

  .download-thumb {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .download-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .download-kat {
    font-family: var(--font-title);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-teal);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .download-name {
    font-family: var(--font-title);
    font-size: 0.95rem;
    color: var(--color-navy);
    font-weight: 600;
  }

  .download-fmt {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-family: var(--font-title);
  }

  .download-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .anleitung-link {
    font-family: var(--font-title);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .anleitung-link:hover { color: var(--color-teal); }

  .btn-accent svg { vertical-align: middle; margin-right: 3px; }

  @media (max-width: 560px) {
    .download-thumb { display: none; }
    .download-row { padding: 0.85rem 1rem; }
    .anleitung-link { display: none; }
  }

  /* Newsletter section */
  .newsletter-box {
    padding: 4rem 2rem;
  }

  .newsletter-box h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .newsletter-box p {
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1.05rem;
  }

  .social-buttons {
    gap: 20px;
    flex-wrap: wrap;
  }

  /* Simulated Image Specific Gradients */
  .team-gradient {
    background: linear-gradient(135deg, #e0f2fe 0%, #0891b2 100%);
  }
  .halloween-gradient {
    background: linear-gradient(135deg, #1c0a00 0%, #ff6600 60%, #f59e0b 100%);
  }
  .leinwand-gradient {
    background: linear-gradient(135deg, #fce7f3 0%, #c084fc 50%, #0891b2 100%);
  }
  .markt-gradient {
    background: linear-gradient(135deg, #f0fdf4 0%, #4ade80 60%, #34d399 100%);
  }
  .resin-gradient {
    background: linear-gradient(135deg, #e0f2f1 0%, #bad6da 100%);
  }
  .book-gradient {
    background: linear-gradient(135deg, #efebe9 0%, #bad6da 100%);
  }
  .canvas-gradient {
    background: linear-gradient(135deg, #e8f5e9 0%, #bad6da 100%);
  }

  .simulated-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 600;
    color: var(--color-navy);
    font-size: 0.95rem;
  }

  .simulated-image span {
    background-color: rgba(255, 255, 255, 0.85);
    padding: 6px 14px;
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
  }
</style>
