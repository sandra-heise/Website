---
import Layout from '../layouts/Layout.astro';

// Hardcoded sample blog posts for simple maintenance and setup
const blogPosts = [
  {
    id: 1,
    title: "Anleitung: Echte Blüten in Harz eingießen",
    date: "15. Mai 2026",
    category: "Basteln & Schmuck",
    excerpt: "Schritt-für-Schritt-Anleitung, wie du Blumen richtig trocknest und luftblasenfrei in Epoxidharz eingießt, um wunderschöne Schmuckstücke zu erschaffen.",
    gradientClass: "resin-gradient"
  },
  {
    id: 2,
    title: "Die Grundlagen des Schattierens bei Bleistiftzeichnungen",
    date: "28. April 2026",
    category: "Zeichnen Lernen",
    excerpt: "Lerne, wie du durch die richtige Schraffur- und Wischtechnik deinen Zeichnungen mehr Tiefe und Dreidimensionalität verleihst.",
    gradientClass: "book-gradient"
  },
  {
    id: 3,
    title: "Tipps & Tricks für das Arbeiten mit Schneideplottern",
    date: "10. März 2026",
    category: "Plotter Tipps",
    excerpt: "So gelingt das Entgittern feiner SVG-Muster ohne Frust. Die besten Einstellungen für Flexfolien, Vinyl und Papier im Überblick.",
    gradientClass: "canvas-gradient"
  }
];
---

<Layout title="DIY-Blog - Sunny Artis | Bastel- & Zeichenanleitungen" description="Schritt-für-Schritt-Anleitungen zum Zeichnen, Basteln und Arbeiten mit Plotterdateien. Lerne neue kreative Hobbys im Blog von Sandra Heise.">
  <section class="section page-header-section">
    <div class="container text-center">
      <span class="section-tag">KREATIV-BLOG</span>
      <h1 class="center-title">Mein kreativer Ratgeber</h1>
      <p class="section-desc">
        Ich teile meine Leidenschaft gerne mit anderen. In meinem Blog findest du praktische Anleitungen, Tipps fürs Zeichnen und kreative Ideen für deine eigenen DIY-Projekte.
      </p>
    </div>
  </section>

  <!-- Blog Posts List -->
  <section class="section blog-list-section bg-light">
    <div class="container">
      <div class="grid-3 blog-grid">
        {blogPosts.map(post => (
          <article class="card blog-card">
            <div class="card-img-wrapper">
              <div class={`simulated-image ${post.gradientClass}`}>
                <span>{post.category}</span>
              </div>
              <span class="badge badge-navy card-badge">{post.date}</span>
            </div>
            <div class="card-content">
              <span class="blog-category">{post.category}</span>
              <h3 class="card-title blog-post-title">{post.title}</h3>
              <p class="card-text">{post.excerpt}</p>
              <div class="card-footer">
                <a href="#" class="read-more-link">
                  <span>Weiterlesen</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter Teaser (Static / Info) -->
  <section class="section newsletter-teaser">
    <div class="container">
      <div class="glass-container newsletter-box text-center">
        <h2>Bleibe kreativ auf dem Laufenden</h2>
        <p>
          Verpasse keine neuen Zeichnungen, DIY-Anleitungen oder Angebote. Folge mir am besten auf meinen Social-Media-Kanälen, wo ich regelmäßig Einblicke in meine Arbeit gebe.
        </p>
        <div class="social-buttons flex-center">
          <a href="https://www.instagram.com/sunny_artis" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Instagram folgen</a>
          <a href="https://www.youtube.com/@sunny_artis" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">YouTube abonnieren</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-category {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-teal);
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
  }

  .blog-post-title {
    font-size: 1.2rem;
    line-height: 1.4;
    margin-bottom: 12px;
  }

  .read-more-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-teal);
    transition: all var(--transition-fast);
  }

  .read-more-link:hover {
    color: var(--color-navy);
  }

  .read-more-link svg {
    transition: transform var(--transition-fast);
  }

  .read-more-link:hover svg {
    transform: translateX(4px);
  }

  /* Newsletter section */
  .newsletter-box {
    padding: 4rem 2rem;
  }

  .newsletter-box h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .newsletter-box p {
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1.05rem;
  }

  .social-buttons {
    gap: 20px;
    flex-wrap: wrap;
  }

  /* Simulated Image Specific Gradients */
  .resin-gradient {
    background: linear-gradient(135deg, #e0f2f1 0%, #bad6da 100%);
  }
  .book-gradient {
    background: linear-gradient(135deg, #efebe9 0%, #bad6da 100%);
  }
  .canvas-gradient {
    background: linear-gradient(135deg, #e8f5e9 0%, #bad6da 100%);
  }

  .simulated-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 600;
    color: var(--color-navy);
    font-size: 0.95rem;
  }

  .simulated-image span {
    background-color: rgba(255, 255, 255, 0.85);
    padding: 6px 14px;
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
  }
</style>
