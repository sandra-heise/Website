---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const malbuecher = [
  {
    title: "Fantasie in Farbe",
    subtitle: "Für Teenager & Mädchen",
    preis: "ab 9,99€",
    beschreibung: "25 geometrische Motive mit abstrakten Mustern — meditativ und kreativ zugleich. Ideal zum Stressabbau, für Buntstifte und Filzstifte geeignet.",
    image: `${base}/malbuecher/fantasie-in-farbe-teenager.jpg`,
    gradient: "bg-mb-1",
    etsy:   "https://www.etsy.com/de/listing/1437110610/malbuch-fur-teenager-25-fantasievolle",
    amazon: "https://amzn.eu/d/0fHK8OFe",
  },
  {
    title: "Fantasie in Farbe 2",
    subtitle: "Band 2 der Reihe",
    preis: "ab 9,99€",
    beschreibung: "25 neue Motive in den Genres Fantasy, Surreal und Anime — die Fortsetzung der beliebten Reihe, mit frischen Designs und neuen Zitaten.",
    image: `${base}/malbuecher/fantasie-in-farbe-2.jpg`,
    gradient: "bg-mb-5",
    etsy:   "https://www.etsy.com/de/listing/1784178213/malbuch-fur-teenager-jungs-und-madchen",
    amazon: "https://amzn.eu/d/08cUPLaU",
  },
  {
    title: "Malbuch Magie",
    subtitle: "Fantasie in Farbe",
    preis: "ab 9,99€",
    beschreibung: "25 magische Motive und 25 inspirierende Zitate. Geometrische Symbole und Mandalas — für Kinder ab 6, Teenager und Erwachsene.",
    image: `${base}/malbuecher/malbuch-magie.jpg`,
    gradient: "bg-mb-2",
    etsy:   "https://www.etsy.com/de/listing/4375183327/magisches-malbuch-fantasie-in-farbe",
    amazon: "https://amzn.eu/d/0ip0GGNt",
  },
  {
    title: "Tiere & Fabelwesen",
    subtitle: "Fantasie in Farbe",
    preis: "ab 9,99€",
    beschreibung: "25 fantasievolle Motive — Einhörner, Drachen und mystische Kreaturen mit geometrischen Details. Für Kinder und Teenager.",
    image: `${base}/malbuecher/tiere-fabelwesen.jpg`,
    gradient: "bg-mb-3",
    etsy:   "https://www.etsy.com/de/listing/1843977329/malbuch-fur-teenager-jungs-madchen",
    amazon: "https://amzn.eu/d/0hlSpSif",
  },
  {
    title: "Mensch & Anime",
    subtitle: "Fantasie in Farbe",
    preis: "ab 9,99€",
    beschreibung: "25 Motive rund um Menschen und Anime-Figuren mit geometrischen Designs und 25 inspirierenden Zitaten.",
    image: `${base}/malbuecher/mensch-anime.jpg`,
    gradient: "bg-mb-4",
    etsy:   "https://www.etsy.com/de/listing/1727809252/malbuch-fur-teenager-junge-madchen",
    amazon: "https://amzn.eu/d/01Q9CMiw",
  },
];

const leinwaende = [
  {
    titel: "Ausmalleinwände – Kollektion 1",
    beschreibung: "8 verschiedene Motive zur Auswahl — von zarten Tiermotiven bis zur eleganten Ballerina. Dein Wunschmotiv wählst du direkt auf Etsy.",
    motive: ["Schildkröten", "Ballerina", "Hase", "Meerjungfrau", "Katze", "Drache", "Tattoo Mädchen", "Blume mit Frau"],
    images: [
      `${base}/leinwaende/thumbnail_schildkroete.jpg`,
      `${base}/leinwaende/thumbnail_ballerina.jpg`,
      `${base}/leinwaende/Hasethumbnail.jpg`,
      `${base}/leinwaende/meerjungfrauthumbnail.jpg`,
      `${base}/leinwaende/katzethumbnail.jpg`,
      `${base}/leinwaende/thumbnail_drache.jpg`,
      `${base}/leinwaende/Mädchen auf Blume.jpg`,
      `${base}/leinwaende/maedchentattoothumbnail.jpg`,
    ],
    format: "20 × 30 cm",
    preis: "8,95 €",
    etsy: "https://www.etsy.com/de/listing/1657906760/leinwande-mit-unterschiedlichen-motiven",
  },
  {
    titel: "Ausmalleinwände – Kollektion 2",
    beschreibung: "9 weitere Motive zur Auswahl — von verspielten Tieren bis zu starken Frauenfiguren. Dein Wunschmotiv wählst du direkt auf Etsy.",
    motive: ["Einhorn", "Papageien", "Mädchen bei Nacht", "Mädchen mit Teddy", "Crazy Dog", "Gesicht mit Blumen", "Selbstbewusste Frau", "Eule mit Amulett", "Auge"],
    images: [
      `${base}/leinwaende/Einhorn.jpg`,
      `${base}/leinwaende/Papagei.jpg`,
      `${base}/leinwaende/Mädchen mit Mond.jpg`,
      `${base}/leinwaende/Mädchen mit Teddy.jpg`,
      `${base}/leinwaende/Crazydog.jpg`,
      `${base}/leinwaende/Blumengesicht.jpg`,
      `${base}/leinwaende/Frau mit Stern.jpg`,
      `${base}/leinwaende/Eule.jpg`,
      `${base}/leinwaende/Auge.jpg`,
    ],
    format: "20 × 30 cm",
    preis: "8,95 €",    
    etsy: "https://www.etsy.com/de/listing/1464917977/leinwand-zum-ausmalen-motive-auf",
  },
];

// YouTube Shorts: einfach die komplette URL einfügen
const shorts = [
  { url: "https://www.youtube.com/shorts/xAR91ojxoqI" },
  { url: "https://www.youtube.com/shorts/lgnwiBTzAJA" },
  { url: "https://www.youtube.com/shorts/t9JDbgNkRis" },
  { url: "https://www.youtube.com/shorts/_Rxqb_5Lajo" },
];

function youtubeId(url: string): string {
  const m = url.match(/(?:shorts\/|v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  return m ? m[1] : url;
}

const shortsAktiv = shorts.filter(v => v.url && !v.url.startsWith("YOUTUBE"));

const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/malen`;
const ogImage = `${SITE}/blog/ausmalen-leinwand-hero.jpg`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Malbücher & Ausmalleinwände – Kreatives Ausmalen von Sandra Heise",
  "description": "Handgezeichnete Malbücher und vorgestaltete Ausmalleinwände von Sandra Heise. Für Kinder, Teenager und Erwachsene.",
  "url": canonicalUrl,
  "inLanguage": "de",
  "author": {
    "@type": "Person",
    "name": "Sandra Heise",
    "url": SITE,
    "sameAs": [
      "https://www.instagram.com/sunny_artis/",
      "https://www.youtube.com/@SunnyArtis",
      "https://www.etsy.com/de/shop/SunnyArtis"
    ]
  },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": malbuecher.length + leinwaende.length,
    "itemListElement": [
      ...malbuecher.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Book",
          "name": `${b.title} – ${b.subtitle}`,
          "description": b.beschreibung,
          "author": { "@type": "Person", "name": "Sandra Heise" },
          "inLanguage": "de",
          "url": b.etsy,
          "offers": [
            { "@type": "Offer", "price": "9.99", "priceCurrency": "EUR", "availability": "https://schema.org/InStock", "url": b.etsy, "seller": { "@type": "Organization", "name": "Etsy" } },
            { "@type": "Offer", "price": "9.99", "priceCurrency": "EUR", "availability": "https://schema.org/InStock", "url": b.amazon, "seller": { "@type": "Organization", "name": "Amazon" } }
          ]
        }
      })),
      ...leinwaende.map((l, i) => ({
        "@type": "ListItem",
        "position": malbuecher.length + i + 1,
        "item": {
          "@type": "Product",
          "name": l.titel,
          "description": l.beschreibung,
          "brand": { "@type": "Brand", "name": "Sunny Artis" },
          "url": l.etsy,
          "offers": {
            "@type": "Offer",
            "price": "8.95",
            "priceCurrency": "EUR",
            "availability": "https://schema.org/InStock",
            "url": l.etsy,
            "seller": { "@type": "Person", "name": "Sandra Heise" }
          }
        }
      }))
    ]
  }
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was sind Ausmalleinwände?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ausmalleinwände sind vorgedruckte Leinwände auf stabilem Keilrahmen mit fantasievollen Motiven. Du bemalst sie mit Acryl- oder Ölfarben in deinen Wunschfarben — am Ende hängst du ein echtes, einzigartiges Kunstwerk an die Wand. Jede Leinwand ist 20 × 30 cm groß und enthält ein Beispielbild zur Orientierung." }
    },
    {
      "@type": "Question",
      "name": "Welche Farben brauche ich für Ausmalleinwände?",
      "acceptedAnswer": { "@type": "Answer", "text": "Am besten eignen sich Acrylfarben — sie trocknen schnell, sind einfach zu handhaben und für Einsteiger ideal. Ölfarben sind ebenfalls möglich und ermöglichen weichere Farbübergänge. Buntstifte oder Filzstifte sind nicht geeignet." }
    },
    {
      "@type": "Question",
      "name": "Für welches Alter sind die Ausmalleinwände geeignet?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die Ausmalleinwände sind für Kinder ab ca. 10 Jahren, Teenager und Erwachsene geeignet. Es gibt Motive in verschiedenen Schwierigkeitsgraden — von leicht (ideal für Einsteiger) bis fortgeschritten (für detailverliebte Ausmalende)." }
    },
    {
      "@type": "Question",
      "name": "Was kostet eine Ausmalleinwand?",
      "acceptedAnswer": { "@type": "Answer", "text": "Unsere Ausmalleinwände kosten 8,95 € zzgl. Versand. Du kannst aus insgesamt 17 verschiedenen Motiven wählen — Tiere, Fantasiefiguren, Frauen und mehr. Erhältlich auf Etsy." }
    },
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen einem Malbuch und einer Ausmalleinwand?",
      "acceptedAnswer": { "@type": "Answer", "text": "In Malbüchern arbeitest du auf Papier mit Buntstiften oder Filzstiften. Auf einer Ausmalleinwand verwendest du Acryl- oder Ölfarben auf echter Leinwand — die Farben sind intensiver, die Textur verleiht dem Bild Tiefe, und das fertige Werk kann direkt aufgehängt werden." }
    },
    {
      "@type": "Question",
      "name": "Wo kann ich die Malbücher kaufen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die Malbücher der Reihe 'Fantasie in Farbe' sind auf Etsy und Amazon erhältlich. Ab 9,99 € erhältst du 50 Seiten mit 25 einzigartigen Motiven im Format 20 × 25 cm, geeignet für Buntstifte und Filzstifte." }
    }
  ]
};
---

<Layout
  title="Malbücher & Ausmalleinwände kaufen – Kreativ Ausmalen mit Acryl | Sunny Artis"
  description="Handgezeichnete Malbücher und vorgestaltete Ausmalleinwände von Sandra Heise — 17 Motive, 20 × 30 cm, ab 8,95 €. Für Kinder, Teenager und Erwachsene. Auf Etsy & Amazon."
  ogImage={ogImage}
  canonical={canonicalUrl}
>
  <meta name="keywords" content="Ausmalleinwand, Leinwand zum Ausmalen, Malbuch Teenager, Ausmalen auf Leinwand, Acrylfarben Anfänger, Kreativgeschenk, Malbuch Erwachsene, Fantasie in Farbe, Sunny Artis" slot="head" />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Malbücher & Ausmalleinwände", "item": canonicalUrl }
    ]
  })} />

  <!-- Hero -->
  <section class="hero-malen">
    <div class="container">
      <div class="hero-split">
        <div class="hero-text">
          <span class="section-tag">KREATIVE AUSMALPRODUKTE</span>
          <h1>Kreativ werden.<br/>Farbe rein.</h1>
          <p>Malbücher und vorgestaltete Leinwände — handgezeichnet, für alle Altersgruppen. Kein Talent nötig, nur Lust auf Farbe.</p>
          <div class="hero-ctas">
            <a href="#malbuecher" class="btn btn-primary">Malbücher</a>
            <a href="#leinwaende" class="btn btn-secondary">Leinwände</a>
          </div>
        </div>
        <div class="hero-buecher-visual">
          <img
            src={`${base}/malbuecher/Vorschaubild_1_Inhalt_Fantasie_in_Farbe.jpg`}
            alt="Inhalt Fantasie in Farbe – Malbuch von Sandra Heise"
            class="hero-buch-img"
            fetchpriority="high"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Malbücher -->
  <section class="section bg-light" id="malbuecher">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">MALBÜCHER</span>
        <h2 class="center-title">Handgezeichnete Malbücher</h2>
        <p class="section-desc">50 Seiten, 25 einzigartige Motive — auf Etsy und Amazon erhältlich. Alle Bücher im Format 20 × 25 cm, geeignet für Buntstifte und Filzstifte.</p>
      </div>
      <div class="grid-3 mb-grid">
        {malbuecher.map(b => (
          <article class="card mb-card">
            <div class={`card-img-wrapper mb-cover ${b.gradient}`}>
              <img src={b.image} alt={`${b.title} – ${b.subtitle}, Malbuch von Sandra Heise`} loading="lazy" />
              <span class="badge badge-teal card-badge">{b.preis}</span>
            </div>
            <div class="card-content">
              <h3 class="card-title">{b.title}</h3>
              <p class="mb-subtitle">{b.subtitle}</p>
              <p class="card-text">{b.beschreibung}</p>
              <p class="mb-meta">50 Seiten · 25 Motive · 20 × 25 cm</p>
              <div class="mb-actions">
                <a href={b.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-partner btn-sm">
                  Etsy
                </a>
                <a href={b.amazon} target="_blank" rel="noopener noreferrer" class="btn btn-amazon btn-sm">
                  Amazon
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  
  <!-- Shorts (nur anzeigen wenn IDs eingetragen) -->
  {shortsAktiv.length > 0 && (
    <section class="section shorts-section bg-light">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-tag">SCHAU REIN</span>
          <h2 class="center-title">Kurze Videos zu meinen Ausmaldesigns</h2>
             </div>
        <div class="shorts-grid">
          {shortsAktiv.map(v => (
            <div class="short-wrapper">
              <iframe
                src={`https://www.youtube.com/embed/${youtubeId(v.url)}`}
                title="YouTube Short"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Warum Ausmalen auf Leinwand -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text">
          <span class="section-tag">EIN NEUES AUSMALERLEBNIS</span>
          <h2>Mehr als ein Malbuch</h2>
          <p>
            Ausmalen hat sich längst zur echten Kunstform entwickelt. Meine Leinwände gehen einen Schritt weiter als klassische Malbücher: Statt Buntstiften kommen Acryl- oder Ölfarben zum Einsatz — das Ergebnis ist intensiver, die Oberfläche lebendiger.
          </p>
          <p>
            Die geometrischen Muster erlauben es, mehrere Farbtöne innerhalb einer Fläche zu kombinieren — ähnlich wie Mandalas oder Kirchenfenster. Welche Farben du wählst, entscheidest ganz du — kein Malen nach Zahlen, sondern echte kreative Freiheit.
          </p>
        </div>
        <ul class="intro-features">
          <li>
            <span class="feat-icon">🎨</span>
            <div>
              <strong>Leinwand statt Papier</strong>
              <span>Acryl- und Ölfarben auf hochwertigem Malgrund — für intensivere Farben und ein echtes Gemälde am Ende.</span>
            </div>
          </li>
          <li>
            <span class="feat-icon">✦</span>
            <div>
              <strong>Geometrische Designs</strong>
              <span>Fantasievolle Muster erlauben unendlich viele Farbkombinationen — jedes Ergebnis ist ein Unikat.</span>
            </div>
          </li>
          <li>
            <span class="feat-icon">🧘</span>
            <div>
              <strong>Meditativ & entspannend</strong>
              <span>Ausmalen reduziert Stress und fördert Konzentration — für Kinder, Teenager und Erwachsene gleichermaßen.</span>
            </div>
          </li>
          <li>
            <span class="feat-icon">🎁</span>
            <div>
              <strong>Perfektes Geschenk</strong>
              <span>Als fertige Leinwand zum Aufhängen oder als Malbuch zum Verschenken — kreativ und persönlich.</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>


  <!-- Ausmalleinwände -->
  <section class="section lw-section bg-light" id="leinwaende">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">AUSMALLEINWÄNDE</span>
        <h2 class="center-title">Leinwände zum Selberbemalen</h2>
        <p class="section-desc">Vorgedruckte Leinwände auf stabilem Keilrahmen — Acryl- oder Ölfarben drauf und los. Jede Leinwand ist 20 × 30 cm groß und kommt mit einem Beispielbild.</p>
      </div>
      <div class="grid-2 lw-grid">
        {leinwaende.map(l => (
          <article class="card lw-card">
            <div class="card-img-wrapper lw-cover">
              <div class="lw-collage">
                {l.images.map((src, i) => (
                  <img src={src} alt={`${l.titel} – Motiv ${i + 1}`} loading="lazy" />
                ))}
              </div>
              <span class="badge badge-teal card-badge">{l.preis}</span>
            </div>
            <div class="card-content">
              <h3 class="card-title">{l.titel}</h3>
              <p class="card-text">{l.beschreibung}</p>
              <ul class="lw-motive-liste">
                {l.motive.map(m => <li>{m}</li>)}
              </ul>
              <div class="lw-meta">
                <span class="lw-format">{l.format} · mit Beispielbild</span>
                <span class="lw-preis">{l.preis}</span>
              </div>
              <div class="card-footer">
                <a href={l.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-partner btn-sm">
                  Auf Etsy ansehen
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog-Tipp -->
  <section class="section blog-tipp-section">
    <div class="container">
      <div class="blog-tipp-card">
        <div class="blog-tipp-text">
          <span class="section-tag">AUS DEM BLOG</span>
          <h2>Magie auf Leinwand: Kreatives Ausmalen von fantasievollen Motiven</h2>
          <p>Wie Acrylfarben, geometrische Muster und eine vorgedruckte Leinwand zusammen echte Kunst ergeben — und warum das viel mehr Spaß macht als ein Malbuch.</p>
          <a href={`${base}/blog/ausmalen-leinwand`} class="btn btn-accent">Artikel lesen</a>
        </div>
        <div class="blog-tipp-images">
          <img src={`${base}/blog/ausmalen-leinwand-1.jpg`} alt="Ausgemalte Leinwand – Beispiel aus dem Blog" loading="lazy" />
          <img src={`${base}/blog/ausmalen-leinwand-2.jpg`} alt="Fertige Ausmalleinwand von Sandra Heise" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Social CTA -->
  <section class="section">
    <div class="container">
      <div class="glass-container social-cta text-center">
        <h2>Folge mir für neue Produkte & Einblicke</h2>
        <p>Ich teile regelmäßig neue Motive, Ausmal-Ergebnisse und Einblicke in meine Arbeit auf Instagram und YouTube.</p>
        <div class="social-actions flex-center">
          <a href="https://www.instagram.com/sunny_artis/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Instagram</a>
          <a href="https://www.youtube.com/@SunnyArtis" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">YouTube</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero-malen {
    padding: 5rem 0 4rem;
    background: var(--color-bg-white);
  }

  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text h1 {
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    line-height: 1.1;
    margin: 0.75rem 0 1.25rem;
    color: var(--color-navy);
  }

  .hero-text p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-buecher-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-buch-img {
    width: 100%;
    max-width: 480px;
    height: auto;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    object-fit: cover;
  }

  /* alt: Buchstapel (nicht mehr genutzt, kann entfernt werden) */
  .buch-stack {
    position: relative;
    width: 160px;
    height: 220px;
  }

  .buch-card {
    position: absolute;
    width: 130px;
    height: 175px;
    border-radius: 4px 8px 8px 4px;
    box-shadow: var(--shadow-md);
  }

  .bc-1 { top: 0; left: 0; transform: rotate(-10deg); z-index: 1; }
  .bc-2 { top: 15px; left: 15px; transform: rotate(-3deg); z-index: 2; }
  .bc-3 { top: 30px; left: 30px; transform: rotate(4deg); z-index: 3; }

  .leinwand-mini {
    width: 90px;
    height: 130px;
    border: 6px solid var(--color-navy);
    border-radius: 3px;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .hero-split { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-buecher-visual { justify-content: flex-start; }
  }

  /* Section helpers */
  .section-tag {
    font-family: var(--font-title);
