---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const malbuecher = [
  {
    title: "Fantasie in Farbe",
    subtitle: "Für Teenager & Mädchen",
    preis: "ab 9,99€",
    beschreibung: "25 geometrische Motive mit abstrakten Mustern — meditativ und kreativ zugleich. Ideal zum Stressabbau, für Buntstifte und Filzstifte geeignet.",
    image: `${base}/malbuecher/fantasie-in-farbe-teenager.jpg`,
    gradient: "bg-mb-1",
    etsy:   "https://www.etsy.com/de/listing/1437110610/malbuch-fur-teenager-25-fantasievolle",
    amazon: "https://amzn.eu/d/0fHK8OFe",
  },
  {
    title: "Fantasie in Farbe 2",
    subtitle: "Band 2 der Reihe",
    preis: "ab 9,99€",
    beschreibung: "25 neue Motive in den Genres Fantasy, Surreal und Anime — die Fortsetzung der beliebten Reihe, mit frischen Designs und neuen Zitaten.",
    image: `${base}/malbuecher/fantasie-in-farbe-2.jpg`,
    gradient: "bg-mb-5",
    etsy:   "https://www.etsy.com/de/listing/1784178213/malbuch-fur-teenager-jungs-und-madchen",
    amazon: "https://amzn.eu/d/08cUPLaU",
  },
  {
    title: "Malbuch Magie",
    subtitle: "Fantasie in Farbe",
    preis: "ab 9,99€",
    beschreibung: "25 magische Motive und 25 inspirierende Zitate. Geometrische Symbole und Mandalas — für Kinder ab 6, Teenager und Erwachsene.",
    image: `${base}/malbuecher/malbuch-magie.jpg`,
    gradient: "bg-mb-2",
    etsy:   "https://www.etsy.com/de/listing/4375183327/magisches-malbuch-fantasie-in-farbe",
    amazon: "https://amzn.eu/d/0ip0GGNt",
  },
  {
    title: "Tiere & Fabelwesen",
    subtitle: "Fantasie in Farbe",
    preis: "ab 9,99€",
    beschreibung: "25 fantasievolle Motive — Einhörner, Drachen und mystische Kreaturen mit geometrischen Details. Für Kinder und Teenager.",
    image: `${base}/malbuecher/tiere-fabelwesen.jpg`,
    gradient: "bg-mb-3",
    etsy:   "https://www.etsy.com/de/listing/1843977329/malbuch-fur-teenager-jungs-madchen",
    amazon: "https://amzn.eu/d/0hlSpSif",
  },
  {
    title: "Mensch & Anime",
    subtitle: "Fantasie in Farbe",
    preis: "ab 9,99€",
    beschreibung: "25 Motive rund um Menschen und Anime-Figuren mit geometrischen Designs und 25 inspirierenden Zitaten.",
    image: `${base}/malbuecher/mensch-anime.jpg`,
    gradient: "bg-mb-4",
    etsy:   "https://www.etsy.com/de/listing/1727809252/malbuch-fur-teenager-junge-madchen",
    amazon: "https://amzn.eu/d/01Q9CMiw",
  },
];

const leinwaende = [
  {
    title: "Einhorn",
    format: "20 × 30 cm",
    schwierigkeit: "Leicht",
    preis: "9,95 €",
    beschreibung: "Ein verspieltes Einhorn voller Stärke und Anmut — ideal für Einsteiger und als Geschenk.",
    gradient: "bg-lw-einhorn",
    status: "verfügbar", // <- "ausverkauft" setzen wenn nötig
    etsy: "ETSY_LINK_LEINWAND_EINHORN",
  },
  {
    title: "Drache",
    format: "20 × 30 cm",
    schwierigkeit: "Mittel",
    preis: "9,95 €",
    beschreibung: "Ein detailreicher Drache mit fantasievollen geometrischen Mustern — für alle, die beim Ausmalen eintauchen möchten.",
    gradient: "bg-lw-drache",
    status: "verfügbar",
    etsy: "ETSY_LINK_LEINWAND_DRACHE",
  },
  {
    title: "Ballerina",
    format: "20 × 30 cm",
    schwierigkeit: "Fortgeschritten",
    preis: "9,95 €",
    beschreibung: "Eine elegante Ballerina mit filigranerm Mosaikmuster im Kleid — für erfahrene Ausmalende.",
    gradient: "bg-lw-ballerina",
    status: "verfügbar",
    etsy: "ETSY_LINK_LEINWAND_BALLERINA",
  },
  {
    title: "Schildkröten",
    format: "20 × 30 cm",
    schwierigkeit: "Mittel",
    preis: "9,95 €",
    beschreibung: "Drei liebevoll gestaltete Schildkröten in einer bunten Blumenlandschaft — ruhig, farbfroh und wunderschön.",
    gradient: "bg-lw-schildkroeten",
    status: "verfügbar",
    etsy: "ETSY_LINK_LEINWAND_SCHILDKROETEN",
  },
];

// YouTube Shorts: einfach die komplette URL einfügen
const shorts = [
  { url: "https://www.youtube.com/shorts/xAR91ojxoqI" },
  { url: "https://www.youtube.com/shorts/lgnwiBTzAJA" },
  { url: "https://www.youtube.com/shorts/t9JDbgNkRis" },
  { url: "https://www.youtube.com/shorts/_Rxqb_5Lajo" },
];

function youtubeId(url: string): string {
  const m = url.match(/(?:shorts\/|v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  return m ? m[1] : url;
}

const shortsAktiv = shorts.filter(v => v.url && !v.url.startsWith("YOUTUBE"));

const SITE = "https://www.sunnyartis.de";
const canonicalUrl = `${SITE}/malen`;
const ogImage = `${SITE}/gemaelde/farbenfroh.jpg`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Malbücher & Ausmalleinwände – Kreatives Ausmalen von Sandra Heise",
  "description": "Handgezeichnete Malbücher und vorgestaltete Ausmalleinwände von Sandra Heise. Für Kinder, Teenager und Erwachsene.",
  "url": canonicalUrl,
  "inLanguage": "de",
  "author": { "@type": "Person", "name": "Sandra Heise", "url": SITE },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      ...malbuecher.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Book",
          "name": `${b.title} – ${b.subtitle}`,
          "description": b.beschreibung,
          "author": { "@type": "Person", "name": "Sandra Heise" },
          "inLanguage": "de",
          "offers": { "@type": "Offer", "price": "11.55", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" }
        }
      })),
      ...leinwaende.map((l, i) => ({
        "@type": "ListItem",
        "position": malbuecher.length + i + 1,
        "item": {
          "@type": "Product",
          "name": `Ausmalleinwand ${l.title}`,
          "description": l.beschreibung,
          "brand": { "@type": "Brand", "name": "Sunny Artis" },
          "offers": {
            "@type": "Offer",
            "price": "9.95",
            "priceCurrency": "EUR",
            "availability": l.status === "ausverkauft"
              ? "https://schema.org/OutOfStock"
              : "https://schema.org/InStock"
          }
        }
      }))
    ]
  }
};
---

<Layout
  title="Malbücher & Ausmalleinwände kaufen | Kreatives Ausmalen – Sunny Artis"
  description="Handgezeichnete Malbücher und vorgestaltete Ausmalleinwände von Sandra Heise — für Kinder, Teenager und Erwachsene. Jetzt auf Etsy und Amazon erhältlich."
  ogImage={ogImage}
  canonical={canonicalUrl}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Malen & Kreativprodukte", "item": canonicalUrl }
    ]
  })} />

  <!-- Hero -->
  <section class="hero-malen">
    <div class="container">
      <div class="hero-split">
        <div class="hero-text">
          <span class="section-tag">KREATIVE AUSMALPRODUKTE</span>
          <h1>Kreativ werden.<br/>Farbe rein.</h1>
          <p>Malbücher und vorgestaltete Leinwände — handgezeichnet, für alle Altersgruppen. Kein Talent nötig, nur Lust auf Farbe.</p>
          <div class="hero-ctas">
            <a href="#malbuecher" class="btn btn-primary">Malbücher</a>
            <a href="#leinwaende" class="btn btn-secondary">Leinwände</a>
          </div>
        </div>
        <div class="hero-buecher-visual">
          <img
            src={`${base}/malbuecher/Vorschaubild_1_Inhalt_Fantasie_in_Farbe.jpg`}
            alt="Inhalt Fantasie in Farbe – Malbuch von Sandra Heise"
            class="hero-buch-img"
            fetchpriority="high"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Malbücher -->
  <section class="section bg-light" id="malbuecher">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">MALBÜCHER</span>
        <h2 class="center-title">Handgezeichnete Malbücher</h2>
        <p class="section-desc">50 Seiten, 25 einzigartige Motive — auf Etsy und Amazon erhältlich. Alle Bücher im Format 20 × 25 cm, geeignet für Buntstifte und Filzstifte.</p>
      </div>
      <div class="grid-3 mb-grid">
        {malbuecher.map(b => (
          <article class="card mb-card">
            <div class={`card-img-wrapper mb-cover ${b.gradient}`}>
              <img src={b.image} alt={`${b.title} – ${b.subtitle}, Malbuch von Sandra Heise`} loading="lazy" />
              <span class="badge badge-teal card-badge">{b.preis}</span>
            </div>
            <div class="card-content">
              <h3 class="card-title">{b.title}</h3>
              <p class="mb-subtitle">{b.subtitle}</p>
              <p class="card-text">{b.beschreibung}</p>
              <p class="mb-meta">50 Seiten · 25 Motive · 20 × 25 cm</p>
              <div class="mb-actions">
                <a href={b.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-sm">
                  Etsy
                </a>
                <a href={b.amazon} target="_blank" rel="noopener noreferrer" class="btn btn-amazon btn-sm">
                  Amazon
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  
  <!-- Shorts (nur anzeigen wenn IDs eingetragen) -->
  {shortsAktiv.length > 0 && (
    <section class="section shorts-section bg-light">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-tag">SCHAU REIN</span>
          <h2 class="center-title">Kurze Videos zu meinen Ausmaldesigns</h2>
             </div>
        <div class="shorts-grid">
          {shortsAktiv.map(v => (
            <div class="short-wrapper">
              <iframe
                src={`https://www.youtube.com/embed/${youtubeId(v.url)}`}
                title="YouTube Short"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Warum Ausmalen auf Leinwand -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text">
          <span class="section-tag">EIN NEUES AUSMALERLEBNIS</span>
          <h2>Mehr als ein Malbuch</h2>
          <p>
            Ausmalen hat sich längst zur echten Kunstform entwickelt. Meine Leinwände gehen einen Schritt weiter als klassische Malbücher: Statt Buntstiften kommen Acryl- oder Ölfarben zum Einsatz — das Ergebnis ist intensiver, die Oberfläche lebendiger.
          </p>
          <p>
            Die geometrischen Muster erlauben es, mehrere Farbtöne innerhalb einer Fläche zu kombinieren — ähnlich wie Mandalas oder Kirchenfenster. Welche Farben du wählst, entscheidest ganz du — kein Malen nach Zahlen, sondern echte kreative Freiheit.
          </p>
        </div>
        <ul class="intro-features">
          <li>
            <span class="feat-icon">🎨</span>
            <div>
              <strong>Leinwand statt Papier</strong>
              <span>Acryl- und Ölfarben auf hochwertigem Malgrund — für intensivere Farben und ein echtes Gemälde am Ende.</span>
            </div>
          </li>
          <li>
            <span class="feat-icon">✦</span>
            <div>
              <strong>Geometrische Designs</strong>
              <span>Fantasievolle Muster erlauben unendlich viele Farbkombinationen — jedes Ergebnis ist ein Unikat.</span>
            </div>
          </li>
          <li>
            <span class="feat-icon">🧘</span>
            <div>
              <strong>Meditativ & entspannend</strong>
              <span>Ausmalen reduziert Stress und fördert Konzentration — für Kinder, Teenager und Erwachsene gleichermaßen.</span>
            </div>
          </li>
          <li>
            <span class="feat-icon">🎁</span>
            <div>
              <strong>Perfektes Geschenk</strong>
              <span>Als fertige Leinwand zum Aufhängen oder als Malbuch zum Verschenken — kreativ und persönlich.</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>


  <!-- Ausmalleinwände -->
  <section class="section lw-section bg-light" id="leinwaende">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">AUSMALLEINWÄNDE</span>
        <h2 class="center-title">Leinwände zum Selberbemalen</h2>
        <p class="section-desc">Vorgedruckte Leinwände auf stabilem Keilrahmen — Acryl- oder Ölfarben drauf und los. Jede Leinwand ist 20 × 30 cm groß und kommt mit einem Beispielbild.</p>
      </div>
      <div class="grid-4 lw-grid">
        {leinwaende.map(l => (
          <article class={`card lw-card${l.status === 'ausverkauft' ? ' lw-ausverkauft' : ''}`}>
            <div class="card-img-wrapper lw-cover">
              <div class={`lw-visual ${l.gradient}`}></div>
              <span class={`badge schwierigkeit-badge card-badge badge-${l.schwierigkeit.toLowerCase()}`}>
                {l.schwierigkeit}
              </span>
              {l.status === 'ausverkauft' && (
                <div class="ausverkauft-overlay">Ausverkauft</div>
              )}
            </div>
            <div class="card-content">
              <h3 class="card-title">{l.title}</h3>
              <p class="card-text">{l.beschreibung}</p>
              <div class="lw-meta">
                <span class="lw-format">{l.format}</span>
                <span class="lw-preis">{l.preis}</span>
              </div>
              <div class="card-footer">
                {l.status === 'ausverkauft' ? (
                  <span class="btn btn-disabled btn-sm">Ausverkauft</span>
                ) : (
                  <a href={l.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-sm">
                    Auf Etsy ansehen
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Social CTA -->
  <section class="section">
    <div class="container">
      <div class="glass-container social-cta text-center">
        <h2>Folge mir für neue Produkte & Einblicke</h2>
        <p>Ich teile regelmäßig neue Motive, Ausmal-Ergebnisse und Einblicke in meine Arbeit auf Instagram und YouTube.</p>
        <div class="social-actions flex-center">
          <a href="https://www.instagram.com/sunny_artis/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Instagram</a>
          <a href="https://www.youtube.com/@SunnyArtis" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">YouTube</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero-malen {
    padding: 5rem 0 4rem;
    background: var(--color-bg-white);
  }

  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text h1 {
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    line-height: 1.1;
    margin: 0.75rem 0 1.25rem;
    color: var(--color-navy);
  }

  .hero-text p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-buecher-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-buch-img {
    width: 100%;
    max-width: 480px;
    height: auto;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    object-fit: cover;
  }

  /* alt: Buchstapel (nicht mehr genutzt, kann entfernt werden) */
  .buch-stack {
    position: relative;
    width: 160px;
    height: 220px;
  }

  .buch-card {
    position: absolute;
    width: 130px;
    height: 175px;
    border-radius: 4px 8px 8px 4px;
    box-shadow: var(--shadow-md);
  }

  .bc-1 { top: 0; left: 0; transform: rotate(-10deg); z-index: 1; }
  .bc-2 { top: 15px; left: 15px; transform: rotate(-3deg); z-index: 2; }
  .bc-3 { top: 30px; left: 30px; transform: rotate(4deg); z-index: 3; }

  .leinwand-mini {
    width: 90px;
    height: 130px;
    border: 6px solid var(--color-navy);
    border-radius: 3px;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .hero-split { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-buecher-visual { justify-content: flex-start; }
  }

  /* Section helpers */
  .section-tag {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-header { margin-bottom: 3rem; }

  .section-desc {
    max-width: 620px;
    margin: 0 auto;
    color: var(--color-text-muted);
  }

  /* Intro */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .intro-text h2 { font-size: 2rem; margin-bottom: 1.25rem; }
  .intro-text p { color: var(--color-text-muted); line-height: 1.75; margin-bottom: 1rem; }

  .intro-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .intro-features li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .feat-icon {
    font-size: 1.4rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .intro-features strong {
    display: block;
    color: var(--color-navy);
    font-family: var(--font-title);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .intro-features span {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .intro-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* Shorts */
  .shorts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    align-items: start;
  }

  .short-wrapper {
    position: relative;
    padding-top: 177.78%; /* 9:16 Hochformat */
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    box-shadow: var(--shadow-md);
  }

  .short-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 900px) {
    .shorts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .shorts-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }

  /* Malbücher */
  .mb-card { height: 100%; }

  /* A4-Hochformat ~3:4 */
  .mb-cover { padding-top: 133% !important; height: 0 !important; }

  /* Leinwand 20×30 = 2:3 */
  .lw-cover { padding-top: 150% !important; height: 0 !important; }

  .mb-subtitle {
    font-family: var(--font-title);
    font-size: 0.82rem;
    color: var(--color-teal);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .mb-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-title);
    margin-bottom: 1.25rem;
  }

  .mb-actions { display: flex; gap: 8px; }

  .btn-amazon {
    background-color: #ff9900;
    color: #111;
    border: none;
    font-weight: 700;
    border-radius: 30px;
    padding: 9px 18px;
    font-family: var(--font-title);
    font-size: 0.85rem;
    text-decoration: none;
    transition: background-color var(--transition-normal);
  }

  .btn-amazon:hover { background-color: #e88a00; }

  /* Malbücher Farbverläufe */
  .bg-mb-1 { background: linear-gradient(145deg, #e3f2fd 0%, #7e57c2 100%); }
  .bg-mb-2 { background: linear-gradient(145deg, #fce4ec 0%, #e91e63 100%); }
  .bg-mb-3 { background: linear-gradient(145deg, #e8f5e9 0%, #66bb6a 100%); }
  .bg-mb-4 { background: linear-gradient(145deg, #fff3e0 0%, #ff7043 100%); }
  .bg-mb-5 { background: linear-gradient(145deg, #ede7f6 0%, #01aac1 100%); }

  /* Leinwände */
  .lw-grid { gap: 20px; }

  .lw-card { height: 100%; }

  .lw-visual {
    width: 100%;
    height: 100%;
  }

  .lw-ausverkauft { opacity: 0.75; }

  .ausverkauft-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 1rem;
    color: white;
    letter-spacing: 0.05em;
  }

  .schwierigkeit-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: var(--font-title);
