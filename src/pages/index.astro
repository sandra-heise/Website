---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Sunny Artis - Kunst, Gemälde & kreative Produkte von Sandra Heise">

  <!-- Hero -->
  <section class="hero-section flex-center">
    <div class="container hero-container">
      <div class="hero-content">
        <span class="hero-tagline">KUNSTWERKSTATT AUS MAGDEBURG</span>
        <h1>Kreative Kunst aus Leidenschaft</h1>
        <p class="hero-text">
          Willkommen bei Sunny Artis! Ich bin Sandra Heise — Malerin, Bastlerin und Schmuckmacherin. Hier findest du Original-Gemälde, Kreativprodukte, Plotterdateien, handgemachten Schmuck und vieles mehr.
        </p>
        <div class="hero-actions">
          <a href="https://www.etsy.com/shop/SunnyArtis" target="_blank" rel="noopener noreferrer" class="btn btn-accent">
            <span>Etsy Shop besuchen</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
          </a>
          <a href={`${base}/portfolio`} class="btn btn-secondary">Portfolio ansehen</a>
        </div>
      </div>
      <div class="hero-cards">
        <div class="hero-blob"></div>
        <div class="illus-card illus-1">🎨 Original Gemälde</div>
        <div class="illus-card illus-2">✂️ Plotterdateien</div>
        <div class="illus-card illus-3">✨ Handmade Schmuck</div>
        <div class="illus-card illus-4">📚 Malbücher & Leinwände</div>
      </div>
    </div>
  </section>

  <!-- Bereiche-Übersicht -->
  <section class="section bereiche-section bg-light">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">WAS ICH MACHE</span>
        <h2 class="center-title">Meine Kreativbereiche</h2>
      </div>
      <div class="bereiche-grid">

        <a href={`${base}/gemaelde`} class="bereich-card bereich-gemaelde">
          <div class="bereich-icon">🖼️</div>
          <h3>Gemälde</h3>
          <p>Original-Gemälde in Acryl, Aquarell und Mischtechnik — alle käuflich auf Etsy.</p>
          <span class="bereich-link">Gemälde entdecken →</span>
        </a>

        <a href={`${base}/malen`} class="bereich-card bereich-malen">
          <div class="bereich-icon">🎨</div>
          <h3>Malen & Kreativprodukte</h3>
          <p>Malbücher und Leinwände für eigene Projekte — plus Tipps und Blog-Beiträge.</p>
          <span class="bereich-link">Zum Malbereich →</span>
        </a>

        <a href={`${base}/basteln`} class="bereich-card bereich-basteln">
          <div class="bereich-icon">✂️</div>
          <h3>Basteln & Plotter</h3>
          <p>SVG-Plotterdateien, Bastelprojekte, Materialempfehlungen und kostenlose Downloads.</p>
          <span class="bereich-link">Zum Bastelbereich →</span>
        </a>

        <a href={`${base}/schmuck`} class="bereich-card bereich-schmuck">
          <div class="bereich-icon">💍</div>
          <h3>Schmuck</h3>
          <p>Handgefertigte Unikate aus Epoxidharz und Polymer Clay — auf Anfrage bestellbar.</p>
          <span class="bereich-link">Schmuck ansehen →</span>
        </a>

        <a href={`${base}/portfolio`} class="bereich-card bereich-portfolio">
          <div class="bereich-icon">📸</div>
          <h3>Portfolio</h3>
          <p>Alle Werke auf einen Blick: Gemälde, Porträts, Schmuck, Bastelprojekte und Videos.</p>
          <span class="bereich-link">Portfolio öffnen →</span>
        </a>

        <a href={`${base}/kontakt`} class="bereich-card bereich-kontakt">
          <div class="bereich-icon">✉️</div>
          <h3>Auftragsarbeiten</h3>
          <p>Individuelles Porträt, Wunschgemälde oder Schmuckstück — schreib mir einfach!</p>
          <span class="bereich-link">Anfrage stellen →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Gemälde Teaser -->
  <section class="section teaser-section">
    <div class="container grid-2 align-center-grid">
      <div class="teaser-visual">
        <div class="gemaelde-frame">
          <div class="gemaelde-inner bg-sunset"></div>
        </div>
      </div>
      <div class="teaser-text">
        <span class="section-tag">ORIGINAL-KUNSTWERKE</span>
        <h2>Gemälde für dein Zuhause</h2>
        <p>
          Handgemalte Originale auf Leinwand und Papier — in Acryl, Aquarell und Mischtechnik. Jedes Bild ist ein Unikat und wird sicher verpackt zu dir geliefert.
        </p>
        <div class="teaser-actions">
          <a href={`${base}/gemaelde`} class="btn btn-primary">Alle Gemälde ansehen</a>
          <a href="https://www.etsy.com/shop/SunnyArtis" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Etsy Shop</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Malbücher & Leinwände Teaser -->
  <section class="section teaser-section bg-light">
    <div class="container grid-2 align-center-grid">
      <div class="teaser-text">
        <span class="section-tag">KREATIVPRODUKTE</span>
        <h2>Malbücher & Leinwände</h2>
        <p>
          Perfekt für kreative Auszeiten: Meine handgezeichneten Malbücher und vorgestalteten Leinwände warten darauf, von dir mit Farbe gefüllt zu werden.
        </p>
        <div class="teaser-actions">
          <a href={`${base}/malen`} class="btn btn-primary">Zum Malbereich</a>
          <a href="https://www.etsy.com/shop/SunnyArtis?section_id=45759325" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Malbücher auf Etsy</a>
        </div>
      </div>
      <div class="teaser-visual">
        <div class="visual-stack-mini">
          <div class="vsm-card vsm-1">Mandala Träume</div>
          <div class="vsm-card vsm-2">Florales Ausmalbuch</div>
          <div class="vsm-card vsm-3">Leinwand-Set</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Basteln Teaser -->
  <section class="section teaser-section">
    <div class="container grid-2 align-center-grid">
      <div class="teaser-visual">
        <div class="plotter-visual-mini">
          <div class="pvm-card pvm-1">SVG</div>
          <div class="pvm-card pvm-2">Vinyl</div>
          <div class="pvm-card pvm-3">Textil</div>
          <div class="pvm-card pvm-4">Papier</div>
        </div>
      </div>
      <div class="teaser-text">
        <span class="section-tag">BASTELN & PLOTTER</span>
        <h2>Plotterdateien & Bastelprojekte</h2>
        <p>
          SVG-Dateien für Schneideplotter, Bastelanleitungen, Materialempfehlungen und kostenlose Downloads. Alles für kreative Bastler.
        </p>
        <div class="teaser-actions">
          <a href={`${base}/basteln`} class="btn btn-primary">Zum Bastelbereich</a>
          <a href="https://www.etsy.com/shop/SunnyArtis?section_id=45759329" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Dateien auf Etsy</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Schmuck Teaser -->
  <section class="section teaser-section bg-light">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-tag">HANDARBEIT</span>
        <h2 class="center-title">Handgefertigter Unikatschmuck</h2>
        <p class="section-desc">Jedes Schmuckstück ein Einzelstück — aus Epoxidharz mit echten Blüten und Polymer Clay in modernen Formen.</p>
      </div>
      <div class="grid-3 schmuck-mini-grid">
        <div class="card schmuck-mini-card">
          <div class="smc-preview bg-resin-blue"></div>
          <div class="card-content tc">
            <h3>Harz-Schmuck</h3>
            <p class="card-text">Mit gepressten Blüten und Goldpigmenten.</p>
          </div>
        </div>
        <div class="card schmuck-mini-card">
          <div class="smc-preview bg-polymer"></div>
          <div class="card-content tc">
            <h3>Polymer-Ohrringe</h3>
            <p class="card-text">Modern, leicht, handgeformt.</p>
          </div>
        </div>
        <div class="card schmuck-mini-card">
          <div class="smc-preview bg-ocean"></div>
          <div class="card-content tc">
            <h3>Ketten & Anhänger</h3>
            <p class="card-text">Filigrane Designs mit Naturmaterialien.</p>
          </div>
        </div>
      </div>
      <div class="text-center" style="margin-top: 2.5rem;">
        <a href={`${base}/schmuck`} class="btn btn-outline-dark">Mehr Schmuck ansehen</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero-section {
    min-height: calc(85vh - 90px);
    background: radial-gradient(circle at 80% 20%, rgba(186, 214, 218, 0.3) 0%, transparent 60%),
                radial-gradient(circle at 10% 80%, rgba(251, 205, 10, 0.1) 0%, transparent 50%);
    padding: 4rem 0;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
  }

  @media (max-width: 991px) {
    .hero-container { grid-template-columns: 1fr; text-align: center; gap: 40px; }
    .hero-actions { justify-content: center; }
  }

  .hero-tagline {
    font-family: var(--font-title);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 1rem;
  }

  .hero-content h1 { font-size: 3rem; line-height: 1.15; margin-bottom: 1.5rem; }

  @media (max-width: 768px) { .hero-content h1 { font-size: 2.25rem; } }

  .hero-text {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    max-width: 560px;
  }

  @media (max-width: 991px) { .hero-text { margin-left: auto; margin-right: auto; } }

  .hero-actions { display: flex; gap: 20px; flex-wrap: wrap; }

  .btn-icon { margin-left: 8px; transition: transform var(--transition-fast); }
  .btn:hover .btn-icon { transform: translate(2px, -2px); }

  .hero-cards {
    position: relative;
    height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 991px) { .hero-cards { height: 280px; } }

  .hero-blob {
    position: absolute;
    width: 300px; height: 300px;
    background-color: var(--color-soft-blue);
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    filter: blur(10px);
    opacity: 0.5;
    animation: blob-animate 8s infinite ease-in-out;
    z-index: 1;
  }

  .illus-card {
    position: absolute;
    padding: 13px 20px;
    background-color: var(--color-bg-white);
    border-radius: 12px;
    box-shadow: var(--shadow-md);
    font-family: var(--font-title);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-navy);
    border: 1px solid var(--color-border);
    z-index: 2;
    transition: transform var(--transition-normal);
    white-space: nowrap;
  }

  .illus-card:hover { transform: scale(1.05) !important; }

  .illus-1 { top: 10%; left: 5%; transform: rotate(-6deg); border-left: 4px solid var(--color-teal); }
  .illus-2 { top: 40%; right: 5%; transform: rotate(4deg); border-left: 4px solid var(--color-yellow); }
  .illus-3 { top: 65%; left: 10%; transform: rotate(-3deg); border-left: 4px solid var(--color-soft-blue); }
  .illus-4 { top: 20%; right: 10%; transform: rotate(2deg); border-left: 4px solid #f48fb1; }

  @keyframes blob-animate {
    0%, 100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
    50% { border-radius: 60% 40% 50% 70% / 50% 60% 40% 60%; }
  }

  /* Section header */
  .section-tag {
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    max-width: 600px;
    margin: 0 auto 3rem;
    color: var(--color-text-muted);
  }

  /* Bereiche Grid */
  .bereiche-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 1rem;
  }

  @media (max-width: 991px) { .bereiche-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 576px) { .bereiche-grid { grid-template-columns: 1fr; } }

  .bereich-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px 24px;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 4px solid transparent;
  }

  .bereich-gemaelde { border-top-color: #ef6c00; }
  .bereich-malen { border-top-color: var(--color-teal); }
  .bereich-basteln { border-top-color: #fff59d; border-top-color: #f9a825; }
  .bereich-schmuck { border-top-color: #ad1457; }
  .bereich-portfolio { border-top-color: var(--color-navy); }
  .bereich-kontakt { border-top-color: #a5d6a7; }

  .bereich-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .bereich-icon { font-size: 2rem; }
  .bereich-card h3 { font-size: 1.1rem; margin: 0; }
  .bereich-card p { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.5; margin: 0; flex: 1; }
  .bereich-link { font-family: var(--font-title); font-size: 0.85rem; font-weight: 600; color: var(--color-teal); }

  /* Teaser sections */
  .align-center-grid { align-items: center; }

  .teaser-text h2 { font-size: 1.9rem; margin-bottom: 1rem; }
  .teaser-text p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: 2rem; max-width: 500px; }
  .teaser-actions { display: flex; gap: 14px; flex-wrap: wrap; }

  /* Gemälde frame */
  .gemaelde-frame {
    width: 300px;
    height: 360px;
    border: 10px solid var(--color-navy);
    border-radius: 4px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    margin: 0 auto;
  }

  .gemaelde-inner { width: 100%; height: 100%; }
  .bg-sunset { background: linear-gradient(145deg, #fff3e0, #ff8a65, #c62828); }

  /* Visual stack mini */
  .visual-stack-mini {
    position: relative;
    width: 260px;
    height: 260px;
    margin: 0 auto;
  }

  .vsm-card {
    position: absolute;
    width: 190px;
    height: 220px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-navy);
    box-shadow: var(--shadow-md);
  }

  .vsm-1 { background: linear-gradient(135deg, #e3f2fd, #90caf9); top: 0; left: 0; transform: rotate(-7deg); z-index: 1; }
  .vsm-2 { background: linear-gradient(135deg, #f1f8e9, #a5d6a7); top: 20px; left: 25px; transform: rotate(-1deg); z-index: 2; }
  .vsm-3 { background: linear-gradient(135deg, #fce4ec, #f48fb1); top: 40px; left: 50px; transform: rotate(5deg); z-index: 3; }

  /* Plotter visual mini */
  .plotter-visual-mini {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 260px;
    margin: 0 auto;
  }

  .pvm-card {
    height: 110px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-navy);
    box-shadow: var(--shadow-sm);
  }

  .pvm-1 { background: linear-gradient(135deg, #fffde7, #fff59d); }
  .pvm-2 { background: linear-gradient(135deg, #fce4ec, #f48fb1); }
  .pvm-3 { background: linear-gradient(135deg, #e3f2fd, #90caf9); }
  .pvm-4 { background: linear-gradient(135deg, #f1f8e9, #a5d6a7); }

  /* Schmuck mini */
  .smc-preview {
    height: 160px;
    border-radius: 8px 8px 0 0;
  }

  .bg-resin-blue { background: radial-gradient(ellipse at 30% 30%, #e3f2fd, #1565c0); }
  .bg-polymer { background: radial-gradient(ellipse at 30% 30%, #fce4ec, #ad1457); }
  .bg-ocean { background: radial-gradient(ellipse at 30% 30%, #e0f7fa, #006064); }

  .schmuck-mini-card { overflow: hidden; }
  .tc { text-align: center; }
  .tc h3 { font-size: 1rem; margin-bottom: 4px; }
</style>
