---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE = "https://www.sunnyartis.de";

const featured = {
  title: "Blütengeist – Ausdruck einer Seele",
  technik: "Öl auf Leinwand · 80 × 80 cm",
  preis: "275,00 €",
  image: `${base}/gemaelde/blutengeist.jpg`,
  alt: "Blütengeist – Ölgemälde Frauenporträt umrahmt von Lilien, von Sandra Heise",
  etsy: "https://www.etsy.com/de/listing/4307467400/ol-gemalde-original-frau-mit-blumen",
};

const nebenGemaelde = [
  {
    title: "Silent Crown",
    technik: "Öl auf Leinwand · 80 × 80 cm",
    preis: "525,00 €",
    image: `${base}/gemaelde/silent-crown.jpg`,
    alt: "Silent Crown – Ölgemälde Frauenporträt mit goldener Krone und geschlossenen Augen, von Sandra Heise",
    etsy: "",
    bald: true,
  },
  {
    title: "Vergängliche Stärke",
    technik: "Acryl & Blattgold · 40 × 50 cm",
    preis: "95,00 €",
    image: `${base}/gemaelde/vergaengliche-staerke.jpg`,
    alt: "Vergängliche Stärke – Acrylgemälde Männerporträt mit Blattgold auf Schwarz-Weiß, von Sandra Heise",
    etsy: "https://www.etsy.com/de/listing/4354656293/acryl-gemalde-original-vergangliche",
    bald: false,
  },
  {
    title: "Vergängliche Stärke 2",
    technik: "Acryl & Blattgold · 40 × 50 cm",
    preis: "95,00 €",
    image: `${base}/gemaelde/vergaengliche-staerke-2.jpg`,
    alt: "Vergängliche Stärke 2 – zweites Acrylgemälde der Serie mit Blattgold, von Sandra Heise",
    etsy: "https://www.etsy.com/de/listing/4354656511/acryl-gemalde-original-vergangliche",
    bald: false,
  },
];

const malbuecher = [
  {
    title: "Fantasie in Farbe",
    subtitle: "Für Teenager & Mädchen",
    preis: "ab 9,99 €",
    image: `${base}/malbuecher/fantasie-in-farbe-teenager.jpg`,
    etsy: "https://www.etsy.com/de/listing/1437110610/malbuch-fur-teenager-25-fantasievolle",
    amazon: "https://amzn.eu/d/0fHK8OFe",
  },
  {
    title: "Fantasie in Farbe 2",
    subtitle: "Band 2 der Reihe",
    preis: "ab 9,99 €",
    image: `${base}/malbuecher/fantasie-in-farbe-2.jpg`,
    etsy: "https://www.etsy.com/de/listing/1784178213/malbuch-fur-teenager-jungs-und-madchen",
    amazon: "https://amzn.eu/d/08cUPLaU",
  },
  {
    title: "Malbuch Magie",
    subtitle: "Mandalas & Symbole",
    preis: "ab 9,99 €",
    image: `${base}/malbuecher/malbuch-magie.jpg`,
    etsy: "https://www.etsy.com/de/listing/4375183327/magisches-malbuch-fantasie-in-farbe",
    amazon: "https://amzn.eu/d/0ip0GGNt",
  },
  {
    title: "Tiere & Fabelwesen",
    subtitle: "Einhörner & Drachen",
    preis: "ab 9,99 €",
    image: `${base}/malbuecher/tiere-fabelwesen.jpg`,
    etsy: "https://www.etsy.com/de/listing/1843977329/malbuch-fur-teenager-jungs-madchen",
    amazon: "https://amzn.eu/d/0hlSpSif",
  },
  {
    title: "Mensch & Anime",
    subtitle: "Menschen & Anime-Figuren",
    preis: "ab 9,99 €",
    image: `${base}/malbuecher/mensch-anime.jpg`,
    etsy: "https://www.etsy.com/de/listing/1727809252/malbuch-fur-teenager-junge-madchen",
    amazon: "https://amzn.eu/d/01Q9CMiw",
  },
];

const weiteres = [
  {
    title: "Ausmalleinwände",
    beschreibung: "Vorgestaltete Leinwände — mit deinen Farben zum Leben erweckt.",
    image: `${base}/blog/ausmalen-leinwand-hero.jpg`,
    href: `${base}/malen#leinwaende`,
    cta: "Leinwände ansehen",
  },
  {
    title: "Portraitaufträge",
    beschreibung: "Dein individuelles Porträt nach Foto — in Bleistift oder Aquarell.",
    image: `${base}/portraets/produkte-auftraege.png`,
    href: `${base}/portfolio#portraets`,
    cta: "Aufträge ansehen",
  },
  {
    title: "Handgemachter Schmuck",
    beschreibung: "Unikate aus Epoxidharz und Polymer Clay — auf Anfrage bestellbar.",
    image: `${base}/schmuck/set-3.jpg`,
    href: `${base}/schmuck`,
    cta: "Schmuck entdecken",
  }
];
---

<Layout
  title="Sunny Artis – Handgemalte Gemälde & Kreativprodukte von Sandra Heise"
  description="Original-Gemälde in Öl und Acryl, handgezeichnete Malbücher und Kreativprodukte von Sandra Heise aus Magdeburg. Jedes Werk ein Unikat — bei Etsy und Amazon erhältlich."
  canonical={`${SITE}/`}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sunny Artis",
    "url": SITE,
    "description": "Handgemalte Originalgemälde und Kreativprodukte von Sandra Heise aus Magdeburg.",
    "author": {
      "@type": "Person",
      "name": "Sandra Heise",
      "url": SITE,
      "sameAs": [
        "https://www.etsy.com/shop/SunnyArtis",
        "https://www.instagram.com/sunnyartis_schmuck/"
      ]
    }
  })} />

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero-section">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="hero-tagline">KUNSTWERKSTATT AUS MAGDEBURG</span>
        <h1>Handgemalte Unikate & Kreativprodukte</h1>
        <p class="hero-desc">
          Original-Gemälde in Öl und Acryl, selbst gestaltete Malbücher und mehr — aus echter Leidenschaft für alles Kreative.
        </p>
        <div class="hero-actions">
          <a href="https://www.etsy.com/shop/SunnyArtis" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Gemälde auf Etsy ↗
          </a>
          <a href="#malbucher" class="btn btn-secondary">Malbücher entdecken ↓</a>
        </div>
      </div>
      <div class="hero-visual">
        <img
          src={`${base}/gemaelde/farbenfroh.jpg`}
          alt="Farbenfroh – farbenreiches Ölgemälde von Sandra Heise, fotografiert im Wohnzimmerkontext"
          width="680"
          height="720"
          fetchpriority="high"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ── Gemälde Showcase ──────────────────────────────── -->
  <section class="section gemaelde-section">
    <div class="container">
      <div class="section-intro text-center">
        <span class="section-tag">ORIGINAL-GEMÄLDE</span>
        <h2>Handgemalte Unikate</h2>
        <p class="section-intro-desc">Öl auf Leinwand, Acryl mit Strukturpaste oder Blattgold — jedes Bild entsteht von Hand und ist ein Einzelstück. Direkt auf Etsy kaufen und nach Hause liefern lassen.</p>
      </div>

      <div class="gemaelde-grid">
        <!-- Featured: Blütengeist -->
        <a
          href={featured.etsy}
          target="_blank"
          rel="noopener noreferrer"
          class="gemaelde-card gemaelde-card--featured"
        >
          <div class="gemaelde-img">
            <img
              src={featured.image}
              alt={featured.alt}
              width="600"
              height="700"
              loading="lazy"
            />
            <div class="gemaelde-hover-label">Auf Etsy ansehen ↗</div>
          </div>
          <div class="gemaelde-info">
            <span class="gemaelde-technik">{featured.technik}</span>
            <h3 class="gemaelde-title">{featured.title}</h3>
            <span class="gemaelde-preis">{featured.preis}</span>
          </div>
        </a>

        <!-- Rechte Spalte -->
        <div class="gemaelde-right-col">

          <!-- Silent Crown (bald erhältlich) -->
          <div class="gemaelde-card gemaelde-card--soon">
            <div class="gemaelde-img">
              <img
                src={nebenGemaelde[0].image}
                alt={nebenGemaelde[0].alt}
                width="500"
                height="500"
                loading="lazy"
              />
              <span class="badge-soon">Bald erhältlich</span>
            </div>
            <div class="gemaelde-info">
              <span class="gemaelde-technik">{nebenGemaelde[0].technik}</span>
              <h3 class="gemaelde-title">{nebenGemaelde[0].title}</h3>
              <span class="gemaelde-preis">{nebenGemaelde[0].preis}</span>
              <a href={`${base}/kontakt`} class="soon-notify">Benachrichtigen lassen →</a>
            </div>
          </div>

          <!-- VS1 + VS2 nebeneinander -->
          <div class="gemaelde-pair">
            {nebenGemaelde.slice(1).map(g => (
              <a
                href={g.etsy}
                target="_blank"
                rel="noopener noreferrer"
                class="gemaelde-card gemaelde-card--mini"
              >
                <div class="gemaelde-img">
                  <img src={g.image} alt={g.alt} width="300" height="350" loading="lazy" />
                  <div class="gemaelde-hover-label">Auf Etsy ↗</div>
                </div>
                <div class="gemaelde-info">
                  <span class="gemaelde-technik">{g.technik}</span>
                  <h3 class="gemaelde-title">{g.title}</h3>
                  <span class="gemaelde-preis">{g.preis}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="section-footer text-center">
        <a href={`${base}/gemaelde`} class="btn btn-outline-dark">Alle Gemälde ansehen →</a>
      </div>
    </div>
  </section>

  <!-- ── Malbücher ─────────────────────────────────────── -->
  <section class="section malbucher-section bg-light" id="malbucher">
    <div class="container">
      <div class="section-intro text-center">
        <span class="section-tag">KREATIVPRODUKTE</span>
        <h2>Malbücher für kreative Auszeiten</h2>
        <p class="section-intro-desc">Handgezeichnete Motive zum Ausmalen — für Kinder, Teenager und Erwachsene. Bei Amazon und Etsy erhältlich.</p>
      </div>
      <div class="mb-scroll">
        {malbuecher.map((m) => (
          <article class="mb-card">
            <div class="mb-cover">
              <img
                src={m.image}
                alt={`${m.title} – ${m.subtitle} – Malbuch von Sandra Heise`}
                width="300"
                height="420"
                loading="lazy"
              />
            </div>
            <div class="mb-info">
              <p class="mb-subtitle">{m.subtitle}</p>
              <h3 class="mb-title">{m.title}</h3>
              <p class="mb-preis">{m.preis}</p>
              <div class="mb-actions">
                <a href={m.amazon} target="_blank" rel="noopener noreferrer" class="btn btn-amazon">
                  Amazon
                </a>
                <a href={m.etsy} target="_blank" rel="noopener noreferrer" class="btn btn-etsy">
                  Etsy
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Über mich ─────────────────────────────────────── -->
  <section class="section ueber-section">
    <div class="container ueber-inner">
      <div class="ueber-visual">
        <img
          src={`${base}/portraets/selbstportrait.jpg`}
          alt="Aquarell-Selbstporträt von Sandra Heise – Malerin und Künstlerin aus Magdeburg"
          width="360"
          height="440"
          loading="lazy"
        />
      </div>
      <div class="ueber-text">
        <span class="section-tag">HINTER DER KUNST</span>
        <h2>Hallo, ich bin Sandra</h2>
        <p>
          Kunst ist mein Hobby — und es macht mich glücklich. Ich bilde mich ständig weiter, probiere gerne Neues aus und lasse mich von allem Kreativen begeistern. Ob Malerei, Malbücher, Schmuck oder Basteln: Nicht spezialisiert zu sein ist meine Stärke. Jedes Projekt ist ein neues Experiment.
        </p>
        <a href={`${base}/kontakt`} class="btn btn-secondary">Kontakt aufnehmen →</a>
      </div>
    </div>
  </section>

  <!-- ── Weitere Bereiche ──────────────────────────────── -->
  <section class="section weiteres-section bg-light">
    <div class="container">
      <div class="section-intro text-center">
        <span class="section-tag">MEHR ENTDECKEN</span>
        <h2>Weitere Angebote</h2>
      </div>
      <div class="weiteres-grid">
        {weiteres.map(w => (
          <a href={w.href} class="weiteres-card">
            <div class="weiteres-img">
              <img src={w.image} alt={w.title} width="400" height="280" loading="lazy" />
            </div>
            <div class="weiteres-info">
              <h3>{w.title}</h3>
              <p>{w.beschreibung}</p>
              <span class="weiteres-cta">{w.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero-section {
    padding: 5rem 0 4rem;
    background: linear-gradient(135deg, #fafeff 0%, #f0fafb 60%, #e6f5f8 100%);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-tagline {
    font-family: var(--font-title);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 1.25rem;
  }

  .hero-text h1 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.15;
    color: var(--color-navy);
    margin-bottom: 1.25rem;
  }

  .hero-desc {
    font-size: 1.08rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 2.25rem;
    max-width: 460px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-visual {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(5, 32, 53, 0.18);
    max-height: 560px;
  }

  .hero-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transform: scale(1.09);
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }
    .hero-desc { margin: 0 auto 2rem; }
    .hero-actions { justify-content: center; }
    .hero-visual { max-width: 480px; margin: 0 auto; max-height: 380px; }
  }

  /* ── Section gemeinsam ──────────────────────────────── */
  .section-tag {
    font-family: var(--font-title);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.6rem;
  }

  .section-intro { margin-bottom: 2.75rem; }
  .section-intro h2 { margin-bottom: 0.75rem; }
  .section-intro-desc {
    max-width: 580px;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: 0.97rem;
    line-height: 1.7;
  }

  .section-footer { margin-top: 2.5rem; }

  /* ── Gemälde Grid ───────────────────────────────────── */
  .gemaelde-section { background: var(--color-bg-white); }

  .gemaelde-grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 16px;
  }

  .gemaelde-right-col {
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 16px;
  }

  .gemaelde-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .gemaelde-card {
    background: var(--color-bg-white);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  a.gemaelde-card:hover {
    box-shadow: 0 12px 40px rgba(5, 32, 53, 0.14);
    transform: translateY(-3px);
  }

  .gemaelde-card--soon {
    cursor: default;
    opacity: 0.9;
  }

  .gemaelde-img {
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .gemaelde-card--featured .gemaelde-img { aspect-ratio: 4/5; }
  .gemaelde-card--soon .gemaelde-img { aspect-ratio: 4/3; }
  .gemaelde-card--mini .gemaelde-img { aspect-ratio: 1; }

  .gemaelde-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  a.gemaelde-card:hover .gemaelde-img img { transform: scale(1.04); }

  .gemaelde-hover-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(5, 32, 53, 0.72);
    color: white;
    text-align: center;
    padding: 10px;
    font-family: var(--font-title);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    transform: translateY(100%);
    transition: transform 0.28s ease;
  }

  a.gemaelde-card:hover .gemaelde-hover-label { transform: translateY(0); }

  .soon-notify {
    font-family: var(--font-title);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-teal);
    text-decoration: none;
    margin-top: 6px;
    display: inline-block;
  }

  .soon-notify:hover {
    text-decoration: underline;
  }

  .badge-soon {
    position: absolute;
    top: 12px; right: 12px;
    background: rgba(5, 32, 53, 0.82);
    color: white;
    font-family: var(--font-title);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 5px 12px;
    border-radius: 20px;
  }

  .gemaelde-info {
    padding: 14px 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gemaelde-technik {
    font-family: var(--font-title);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  .gemaelde-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 0;
    line-height: 1.3;
  }

  .gemaelde-card--mini .gemaelde-title { font-size: 0.88rem; }

  .gemaelde-preis {
    font-family: var(--font-title);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-tuerkis);
  }

  @media (max-width: 860px) {
    .gemaelde-grid { grid-template-columns: 1fr; }
    .gemaelde-card--featured .gemaelde-img { aspect-ratio: 4/3; }
    .gemaelde-right-col { grid-template-rows: auto; }
  }

  @media (max-width: 480px) {
    .gemaelde-pair { grid-template-columns: 1fr; }
  }

  /* ── Malbücher ──────────────────────────────────────── */
  .mb-scroll {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 1.25rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .mb-scroll::-webkit-scrollbar { height: 5px; }
  .mb-scroll::-webkit-scrollbar-track { background: transparent; }
  .mb-scroll::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

  .mb-card {
    flex: 0 0 210px;
    scroll-snap-align: start;
    background: var(--color-bg-white);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .mb-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .mb-cover {
    aspect-ratio: 5/7;
    overflow: hidden;
    background: var(--color-bg-light);
    flex-shrink: 0;
  }

  .mb-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .mb-card:hover .mb-cover img { transform: scale(1.04); }

  .mb-info {
    padding: 14px 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-grow: 1;
  }

  .mb-subtitle {
    display: inline-block;
    font-family: var(--font-title);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--color-teal) 12%, transparent);
    border-radius: 20px;
    padding: 3px 10px;
    margin: 0 0 2px;
  }

  .mb-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 0;
    line-height: 1.3;
  }

  .mb-preis {
    font-family: var(--font-title);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-tuerkis);
    margin: 4px 0 0;
  }

  .mb-actions {
    display: flex;
    gap: 8px;
    margin-top: auto;
    padding-top: 12px;
  }

  .btn-amazon {
    flex: 1;
    text-align: center;
    padding: 8px 10px;
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    background: #FF9900;
    color: #111;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .btn-amazon:hover { opacity: 0.85; }

  .btn-etsy {
    flex: 1;
    text-align: center;
    padding: 8px 10px;
    font-family: var(--font-title);
    font-size: 0.8rem;
    font-weight: 700;
    background: #F56400;
    color: white;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

