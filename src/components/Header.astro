---
import { assetPath } from '../utils/assetPath.js';
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="main-header">
  <div class="container header-container">
    <a href={`${base}/`} class="logo-link">
      <div class="logo-wrapper">
        <img src={assetPath('logo.png')} alt="Sunny Artis Logo" class="header-logo" />
      </div>
    </a>

    <button class="nav-toggle" aria-label="Menü öffnen" id="navToggle">
      <span class="hamburger"></span>
    </button>

    <nav class="nav-menu" id="navMenu">
      <ul class="nav-list">
        <li>
          <a href={`${base}/`} class={currentPath === `${base}/` ? 'active' : ''}>Start</a>
        </li>
        <li>
          <a href={`${base}/gemaelde`} class={currentPath.startsWith(`${base}/gemaelde`) ? 'active' : ''}>Gemälde</a>
        </li>
        <li>
          <a href={`${base}/malen`} class={currentPath.startsWith(`${base}/malen`) ? 'active' : ''}>Malen</a>
        </li>
        <li>
          <a href={`${base}/portfolio`} class={currentPath.startsWith(`${base}/portfolio`) ? 'active' : ''}>Portfolio</a>
        </li>
        <li>
          <a href={`${base}/basteln`} class={currentPath.startsWith(`${base}/basteln`) ? 'active' : ''}>Basteln</a>
        </li>
        <li>
          <a href={`${base}/schmuck`} class={currentPath.startsWith(`${base}/schmuck`) ? 'active' : ''}>Schmuck</a>
        </li>
        <li>
          <a href={`${base}/kontakt`} class={currentPath.startsWith(`${base}/kontakt`) ? 'active' : ''}>Kontakt</a>
        </li>
        <li class="etsy-item">
          <a href="https://www.etsy.com/shop/SunnyArtis" target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-sm etsy-link">
            <span>Etsy Shop</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="external-icon"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .main-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background-color: rgb(5, 32, 53);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    height: 90px;
    display: flex;
    align-items: center;
    transition: all var(--transition-normal);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 60px;
    flex-shrink: 0;
  }

  .header-logo {
    height: 100%;
    width: auto;
    object-fit: contain;
  }

  .logo-wrapper {
    width: 60px;
    height: 60px;
    background: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 22px;
  }

  .nav-list a:not(.etsy-link) {
    font-family: var(--font-title);
    font-weight: 500;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    position: relative;
    padding: 10px 0;
    white-space: nowrap;
  }

  .nav-list a:not(.etsy-link):hover,
  .nav-list a:not(.etsy-link).active {
    color: var(--color-teal);
  }

  .nav-list a:not(.etsy-link)::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-teal);
    transition: width var(--transition-fast);
  }

  .nav-list a:not(.etsy-link):hover::after,
  .nav-list a:not(.etsy-link).active::after {
    width: 100%;
  }

  .etsy-link {
    padding: 7px 14px;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 5px;
    text-transform: none;
    box-shadow: none;
  }

  .etsy-link:hover {
    transform: translateY(-1px);
  }

  .external-icon {
    width: 13px;
    height: 13px;
  }

  .nav-toggle {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 1100;
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #ffffff;
    position: relative;
    transition: background-color var(--transition-fast);
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background-color: #ffffff;
    transition: transform var(--transition-fast);
  }

  .hamburger::before { top: -8px; }
  .hamburger::after { bottom: -8px; }

  @media (max-width: 1100px) {
    .nav-toggle {
      display: block;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 300px;
      height: 100vh;
      background-color: rgb(5, 32, 53);
      box-shadow: var(--shadow-lg);
      padding: 100px 40px 40px;
      transition: right var(--transition-normal);
      z-index: 1000;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      overflow-y: auto;
    }

    .nav-menu.open {
      right: 0;
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      width: 100%;
    }

    .nav-list li {
      width: 100%;
    }

    .nav-list a:not(.etsy-link) {
      font-size: 1.1rem;
      display: block;
      width: 100%;
    }

    .etsy-item {
      margin-top: 20px;
      width: 100%;
    }

    .etsy-link {
      width: 100%;
      justify-content: center;
    }

    .nav-toggle.open .hamburger {
      background-color: transparent;
    }

    .nav-toggle.open .hamburger::before {
      transform: translateY(8px) rotate(45deg);
    }

    .nav-toggle.open .hamburger::after {
      transform: translateY(-8px) rotate(-45deg);
    }
  }
</style>

<script>
  const navToggle = document.getElementById('navToggle');
  const navMenu = document.getElementById('navMenu');

  if (navToggle && navMenu) {
    navToggle.addEventListener('click', () => {
      navToggle.classList.toggle('open');
      navMenu.classList.toggle('open');
    });

    navMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navToggle.classList.remove('open');
        navMenu.classList.remove('open');
      });
    });
  }
</script>
