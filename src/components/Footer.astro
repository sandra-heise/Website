---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${base}/`, label: 'Startseite' },
  { href: `${base}/gemaelde`, label: 'Gemälde' },
  { href: `${base}/malen`, label: 'Malen & Kreativprodukte' },
  { href: `${base}/portfolio`, label: 'Portfolio' },
  { href: `${base}/basteln`, label: 'Basteln & Plotter' },
  { href: `${base}/schmuck`, label: 'Schmuck' },
  { href: `${base}/kontakt`, label: 'Kontakt' },
];
---

<footer class="main-footer">
  <div class="container footer-grid">
    <div class="footer-col brand-col">
      <a href={`${base}/`} class="footer-logo">
        <span class="logo-sunny">SUNNY</span><span class="logo-artis"
          >ARTIS</span
        >
      </a>

      <p class="brand-desc">
        Kreative Kunstwerkstatt und Manufaktur aus Magdeburg. Handgefertigter
        Schmuck, Ausmalprodukte und ausdrucksstarke Porträts nach deiner
        Fotovorlage.
      </p>
      <ul class="social-links">
        <li>
          <a
            class="social-icons__link"
            href="https://www.facebook.com/DrawAndMoreART/"
            title="Sunny Artis auf Facebook"
            target="_blank"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="var(--color-teal)"
              aria-hidden="true"
            >
              <path
                d="M23.9981 11.9991C23.9981 5.37216 18.626 0 11.9991 0C5.37216 0 0 5.37216 0 11.9991C0 17.9882 4.38789 22.9522 10.1242 23.8524V15.4676H7.07758V11.9991H10.1242V9.35553C10.1242 6.34826 11.9156 4.68714 14.6564 4.68714C15.9692 4.68714 17.3424 4.92149 17.3424 4.92149V7.87439H15.8294C14.3388 7.87439 13.8739 8.79933 13.8739 9.74824V11.9991H17.2018L16.6698 15.4676H13.8739V23.8524C19.6103 22.9522 23.9981 17.9882 23.9981 11.9991Z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="social-icons__link"
            href="https://twitter.com/sunny_artis"
            title="Sunny Artis auf Twitter"
            target="_blank"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 16 16"
              fill="var(--color-teal)"
              aria-hidden="true"
            >
              <path
                d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="social-icons__link"
            href="https://www.pinterest.de/SunnyArtis/"
            title="Sunny Artis auf Pinterest"
            target="_blank"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 16 16"
              fill="var(--color-teal)"
              aria-hidden="true"
            >
              <path
                d="M8 0a8 8 0 0 0-2.915 15.452c-.07-.633-.134-1.606.027-2.297.146-.625.938-3.977.938-3.977s-.239-.479-.239-1.187c0-1.113.645-1.943 1.448-1.943.682 0 1.012.512 1.012 1.127 0 .686-.437 1.712-.663 2.663-.188.796.4 1.446 1.185 1.446 1.422 0 2.515-1.5 2.515-3.664 0-1.915-1.377-3.254-3.342-3.254-2.276 0-3.612 1.707-3.612 3.473 0 .688.265 1.425.707 1.834.084.077.096.143.07.234-.025.09-.08.315-.103.402-.034.13-.11.158-.25.102-.929-.374-1.51-1.545-1.51-2.483 0-2.015 1.464-3.863 4.226-3.863 2.218 0 3.942 1.583 3.942 3.69 0 2.207-1.397 3.985-3.337 3.985-0.653 0-1.267-.34-1.477-.741l-.403 1.539c-.146.554-.537 1.24-.803 1.658A8 8 0 1 0 8 0z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="social-icons__link"
            href="https://www.instagram.com/sunny_artis/"
            title="Sunny Artis auf Instagram"
            target="_blank"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="var(--color-teal)"
              aria-hidden="true"
            >
              <path
                d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="social-icons__link"
            href="https://www.youtube.com/@SunnyArtis"
            title="Sunny Artis auf YouTube"
            target="_blank"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="var(--color-teal)"
              aria-hidden="true"
            >
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            class="social-icons__link"
            href="https://www.tiktok.com/@sunny_artis"
            title="Sunny Artis auf TikTok"
            target="_blank"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="var(--color-teal)"
              aria-hidden="true"
            >
              <path
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.77 0 2.89 2.89 0 0 1 2.5-2.86v-3.5a6.39 6.39 0 1 0 6.39 6.39V6.69a8.16 8.16 0 0 0 4.1 1.13Z"
              ></path>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="footer-col links-col">
      <h3>Navigation</h3>
      <ul class="footer-links">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col contact-col">
      <h3>Kontakt</h3>
      <p class="contact-info">
        <strong>Sandra Heise</strong><br />
        Magdeburg, Deutschland<br />
        E-Mail: <a href="mailto:sunnyartis@gmx.de">sunnyartis@gmx.de</a><br />
        Telefon: +49 178 7271468
      </p>
      <a
        href="https://www.etsy.com/shop/SunnyArtis"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary btn-sm footer-etsy-btn"
      >
        Zu meinem Etsy-Shop
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-container">
      <p class="copyright">
        &copy; {year} Sunny Artis. Alle Rechte vorbehalten.
      </p>
      <ul class="legal-links">
        <li><a href={`${base}/impressum`}>Impressum</a></li>
        <li><a href={`${base}/datenschutz`}>Datenschutz</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background-color: var(--color-navy);
    color: rgba(255, 255, 255, 0.8);
    padding-top: 5rem;
    margin-top: auto;
    border-top: 4px solid var(--color-teal);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 60px;
    padding-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .footer-col h3 {
    color: var(--color-bg-white);
    font-size: 1.15rem;
    margin-bottom: 1.5rem;
    position: relative;
    padding-bottom: 8px;
  }

  .footer-col h3::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 150px;
    height: 2px;
    background-color: var(--color-teal);
  }

  /* Brand Column */
  .footer-logo {
    display: inline-block;
    font-family: var(--font-logo);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .footer-logo .logo-sunny {
    color: var(--color-teal);
  }

  .footer-logo .logo-artis {
    color: var(--color-bg-white);
  }

  .brand-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 360px;
  }

  .social-links {
    display: flex;
    gap: 15px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    color: var(--color-teal);
    transition: all var(--transition-fast);
  }

  .social-links i {
    font-size: 20px;
    line-height: 1;
    display: inline-block;
  }

  /* Links Column */
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
  }

  .footer-links a:hover {
    color: var(--color-teal);
    padding-left: 5px;
  }

  /* Contact Column */
  .contact-info {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .contact-info a {
    color: var(--color-teal);
  }

  .contact-info a:hover {
    color: var(--color-bg-white);
  }

  .footer-etsy-btn {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-bg-white);
    font-size: 0.85rem;
    padding: 8px 20px;
  }

  .footer-etsy-btn:hover {
    background-color: var(--color-teal);
    border-color: var(--color-teal);
  }

  /* Footer Bottom */
  .footer-bottom {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 15px;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 576px) {
    .footer-bottom-container {
      flex-direction: column;
      text-align: center;
    }
  }

  .legal-links {
    list-style: none;
    display: flex;
    gap: 20px;
  }

  .legal-links a {
    color: rgba(255, 255, 255, 0.5);
  }

  .legal-links a:hover {
    color: var(--color-teal);
  }
</style>
